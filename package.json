{
  "name": "mira-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:api": "bun --filter @shaiz/api dev",
    "dev:all": "bun run dev & bun run dev:api",
    "start:all": "pgrep -x ollama >/dev/null || ollama serve & ngrok http 3000 --url=https://unveiled-walrus-blade.ngrok-free.dev & next dev -p 3000",
    "tunnel": "ngrok http 3000 --url=https://unveiled-walrus-blade.ngrok-free.dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "bun --filter @shaiz/db db:push",
    "db:generate": "bun --filter @shaiz/db db:generate",
    "db:import": "bun --filter @shaiz/db import",
    "mcp:brain": "tsx scripts/mcp-brain.mjs",
    "worker": "tsx --env-file=.env.local worker/index.ts",
    "worker:watch": "tsx watch --env-file=.env.local worker/index.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@xyflow/react": "^12.11.0",
    "better-auth": "^1.6.16",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "ollama": "^0.6.3",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
