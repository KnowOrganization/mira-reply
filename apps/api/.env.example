# @shaiz/api — required environment. Copy to ../../.env.local (repo root) and fill.
# The API + worker are started with `bun --env-file=../../.env.local`.
# NEVER commit real secrets — only this template.

# ── Database (single Postgres; local dev or Supabase) ────────────────────────
DATABASE_URL=postgresql://mira:mira@localhost:5432/mira

# ── Redis (BullMQ queues + atomic dedup/locks) ───────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Meta / Instagram Graph API ───────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
# Public base URL of the web app (tunnel in dev) — used for OAuth redirects.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Auth (BetterAuth — shared @shaiz/auth instance) ──────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM (local Ollama) ───────────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:14b-instruct

# ── Behavior / mode flags ────────────────────────────────────────────────────
MIRA_REPLY_MODE=balanced       # shadow | assisted | balanced | auto
MIRA_STORE=drizzle             # drizzle (Postgres) — file store is legacy
MIRA_WATCHER_DISABLED=1        # 1 = no reconciler poll sweep (webhook-first)
MIRA_OUTBOUND_DISABLED=0       # 1 = drop all outbound sends (testing)

# ── Ports / wiring ───────────────────────────────────────────────────────────
API_PORT=4000                  # Elysia backend port
API_URL=http://localhost:4000  # web → api rewrite target (next.config rewrites)
