    mail:'<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
    phone:'<path d="M5 4h4l2 5-3 2a11 11 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z"/>',
    tag:'<path d="M3 3h7l11 11-7 7L3 10z"/><circle cx="7.5" cy="7.5" r="1.4"/>',
    user:'<path d="M16 19a4 4 0 0 0-8 0"/><circle cx="12" cy="9" r="3"/>',
    eyeoff:'<path d="M2 12s3.5-7 10-7c2 0 3.8.6 5.3 1.5M22 12s-3.5 7-10 7c-2 0-3.8-.6-5.3-1.5"/><path d="m3 3 18 18"/>',
    bell:'<path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6"/><path d="M10 19a2 2 0 0 0 4 0"/>',
    stop:'<circle cx="12" cy="12" r="9"/><rect x="9" y="9" width="6" height="6" rx="1"/>'
  }; return this.ic(M[key]||M.spark,sz); }

  // ---------- node library ----------
  nodeDefs(){ if(this._nd) return this._nd; const T='trigger',C='condition',A='action';
    const L=[
      {t:'comment',cat:T,label:'New comment',sub:'webhook · comments',icon:'comment',fields:[{key:'scope',label:'On which media',kind:'select',opts:['All posts','Specific post','Reels only']},{key:'kw',label:'Only if it contains',kind:'chips'}],sum:c=>c.kw&&c.kw.length?'Comment contains "'+c.kw.join('", "')+'"':'Any new comment · '+(c.scope||'All posts')},
      {t:'dm',cat:T,label:'New DM',sub:'webhook · messages',icon:'dm',fields:[{key:'kw',label:'Only if it contains',kind:'chips'}],sum:c=>c.kw&&c.kw.length?'DM contains "'+c.kw.join('", "')+'"':'Any new direct message'},
      {t:'story_mention',cat:T,label:'Story mention',sub:'webhook · mentions',icon:'mention',fields:[],sum:()=>'Someone @mentions you in a story'},
      {t:'story_reply',cat:T,label:'Story reply',sub:'webhook · messages',icon:'reply',fields:[],sum:()=>'Someone replies to your story'},
      {t:'postback',cat:T,label:'Button tapped',sub:'webhook · messaging_postbacks',icon:'tap',fields:[{key:'payload',label:'Payload equals',kind:'text',ph:'BUY_NOW'}],sum:c=>c.payload?'Taps button "'+c.payload+'"':'Taps any quick-reply / button'},
      {t:'reaction',cat:T,label:'Message reaction',sub:'webhook · message_reactions',icon:'heart',fields:[],sum:()=>'Reacts to one of your messages'},
      {t:'seen',cat:T,label:'Message seen',sub:'webhook · messaging_seen',icon:'eye',fields:[],sum:()=>'Reads your message but no reply'},
      {t:'optin',cat:T,label:'Opt-in',sub:'webhook · messaging_optins',icon:'check',fields:[],sum:()=>'Opts in to notifications'},
      {t:'referral',cat:T,label:'Ad / ref link',sub:'webhook · messaging_referral',icon:'link2',fields:[{key:'ref',label:'Ref / ad id',kind:'text',ph:'summer_sale'}],sum:c=>c.ref?'Starts from ref "'+c.ref+'"':'Starts from an ad or ig.me link'},
      {t:'live_comment',cat:T,label:'Live comment',sub:'webhook · live_comments',icon:'live',fields:[],sum:()=>'Comments during a live broadcast'},
      {t:'contains',cat:C,label:'Text contains',icon:'filter',fields:[{key:'kw',label:'Any of these words',kind:'chips'}],sum:c=>c.kw&&c.kw.length?'Contains '+c.kw.join(' / '):'Message contains a keyword'},
      {t:'is_follower',cat:C,label:'Follower check',icon:'usercheck',fields:[{key:'val',label:'Must be',kind:'select',opts:['A follower','Not a follower']}],sum:c=>(c.val||'A follower')},
      {t:'first_time',cat:C,label:'First-time contact',icon:'spark',fields:[],sum:()=>'Only the first time they reach out'},
      {t:'window',cat:C,label:'24h window',icon:'clock',fields:[{key:'val',label:'Window is',kind:'select',opts:['Open','Closed']}],sum:c=>'24-hour window is '+(c.val||'Open').toLowerCase()},
      {t:'intent',cat:C,label:'AI intent is',icon:'spark',fields:[{key:'val',label:'Detected intent',kind:'select',opts:['Question','Buyer','Praise','Spam','Business']}],sum:c=>'AI reads intent as '+(c.val||'Buyer')},
      {t:'business_hours',cat:C,label:'Business hours',icon:'cal',fields:[],sum:()=>'Only 9am–6pm, Mon–Sat'},
      {t:'split',cat:C,label:'Random A/B split',icon:'branch',fields:[{key:'pct',label:'Send to path A',kind:'number',unit:'%'}],sum:c=>'Split — '+(c.pct||50)+'% take path A'},
      {t:'private_reply',cat:A,label:'Private reply',sub:'primitive · Private Replies',icon:'reply',fields:[{key:'text',label:'Reply text',kind:'area',ph:'Sent it to your DMs 💌'}],sum:c=>c.text||'Reply privately to the comment'},
      {t:'send_dm',cat:A,label:'Send DM',sub:'primitive · Send API',icon:'plane',fields:[{key:'text',label:'Message',kind:'area',ph:'Hey! Thanks for reaching out ✨'}],sum:c=>c.text||'Send a direct message'},
      {t:'send_link',cat:A,label:'Send link',sub:'primitive · Send API',icon:'link2',fields:[{key:'text',label:'Message',kind:'text',ph:"Here's the link"},{key:'url',label:'URL',kind:'text',ph:'dslabs.in/serum'}],sum:c=>c.url?'Link · '+c.url:'Send a link in the DM'},
      {t:'carousel',cat:A,label:'Product carousel',sub:'primitive · Generic Template',icon:'cards',fields:[{key:'set',label:'Show',kind:'select',opts:['Bestsellers','New arrivals','Full catalog']}],sum:c=>'Carousel · '+(c.set||'Bestsellers')},
      {t:'quick_replies',cat:A,label:'Quick replies',sub:'primitive · Quick Replies',icon:'buttons',fields:[{key:'btns',label:'Buttons (max 13)',kind:'chips'}],sum:c=>c.btns&&c.btns.length?c.btns.join(' · '):'Show tappable buttons'},
      {t:'ask_email',cat:A,label:'Ask for email',sub:'Quick Reply · email',icon:'mail',fields:[{key:'text',label:'Prompt',kind:'text',ph:'Drop your email for the discount 👇'}],sum:c=>c.text||'Capture email (consent logged)'},
      {t:'ask_phone',cat:A,label:'Ask for phone',sub:'Quick Reply · phone',icon:'phone',fields:[{key:'text',label:'Prompt',kind:'text',ph:'Share your number for order updates'}],sum:c=>c.text||'Capture phone (consent logged)'},
      {t:'ai_reply',cat:A,label:'AI draft reply',sub:'Assisted · brand voice',icon:'spark',fields:[{key:'tone',label:'Tone',kind:'select',opts:['Warm','Witty','Professional','Hinglish']}],sum:c=>'AI replies in '+(c.tone||'Warm')+' tone'},
      {t:'add_tag',cat:A,label:'Add tag',sub:'CRM',icon:'tag',fields:[{key:'tag',label:'Tag',kind:'text',ph:'advocate'}],sum:c=>c.tag?'Tag contact · '+c.tag:'Add a tag to the contact'},
      {t:'set_status',cat:A,label:'Set lead status',sub:'CRM',icon:'check',fields:[{key:'val',label:'Status',kind:'select',opts:['Cold','Warm','Hot','VIP','Customer']}],sum:c=>'Lead status → '+(c.val||'Warm')},
      {t:'assign',cat:A,label:'Notify / assign',sub:'Handover',icon:'user',fields:[{key:'val',label:'Action',kind:'select',opts:['Notify me','Assign to agent','Escalate']}],sum:c=>(c.val||'Notify me')},
      {t:'wait',cat:A,label:'Wait',sub:'Delay',icon:'clock',fields:[{key:'n',label:'Delay',kind:'number',unit:'min'}],sum:c=>'Wait '+(c.n||5)+' min before next step'},
      {t:'hide_comment',cat:A,label:'Hide comment',sub:'primitive · Moderation',icon:'eyeoff',fields:[],sum:()=>'Hide the comment from the post'},
      {t:'react',cat:A,label:'React / like',sub:'primitive · Reaction',icon:'heart',fields:[{key:'emoji',label:'Reaction',kind:'select',opts:['❤️','🔥','👍','🙏','😍']}],sum:c=>'React with '+(c.emoji||'❤️')},
      {t:'optin_topic',cat:A,label:'Marketing opt-in',sub:'primitive · Marketing Messages',icon:'bell',fields:[{key:'topic',label:'Topic',kind:'text',ph:'Drops & restocks'}],sum:c=>c.topic?'Opt-in topic · '+c.topic:'Add to a marketing topic'},
      {t:'end',cat:A,label:'End flow',sub:'',icon:'stop',fields:[],sum:()=>'Stop the automation here'}
    ];
    const map={}; L.forEach(d=>map[d.t]=d);
    this._nd={list:L,map,triggers:L.filter(d=>d.cat===T),conditions:L.filter(d=>d.cat===C),actions:L.filter(d=>d.cat===A)};
    return this._nd;
  }

  // ---------- onboarding ----------
  connect = () => { if(this.state.connecting) return; this.setState({connecting:true}); setTimeout(()=>this.setState({connecting:false,stage:'brain'}),1700); };
  signIn = () => { if(this.state.gBusy) return; this.setState({gBusy:true}); setTimeout(()=>this.setState({gBusy:false,stage:'intro',introSlide:0}),900); };
  introNext = () => { const n=this.state.introSlide; if(n>=2) this.setState({stage:'connect'}); else this.setState({introSlide:n+1}); };
  introBack = () => { const n=this.state.introSlide; if(n>0) this.setState({introSlide:n-1}); };
  introSkip = () => this.setState({stage:'connect'});
  previewApp = () => this.setState({stage:'app',tab:'home'});
  brainDone = () => this.setState({stage:'app',tab:'home'});

  // ---------- nav ----------
  setTab = (t) => () => this.setState({ tab:t });
  push = (r, extra) => { this.setState(Object.assign({route:r,routeClosing:false},extra||{})); };
  pop = () => { if(this.state.route==='storefront' && this.state.sfProduct){ this.setState({sfProduct:null}); return; } if(this.state.route==='addProduct'){ this.setState({route:'catalog'}); return; } this.setState({routeClosing:true}); setTimeout(()=>this.setState({route:null,activeThread:null,sfProduct:null,routeClosing:false}),320); };
  openSettings = () => { this.setState({sheetMounted:true,sheetClosing:false}); };
  closeSettings = () => { this.setState({sheetClosing:true}); setTimeout(()=>this.setState({sheetMounted:false,sheetClosing:false}),300); };
  setReplyMode = (m) => () => { this.setState({replyMode:m}); };
  setTheme = (t) => () => this.setState({theme:t});
  toggleSetting = (k) => () => this.setState(s=>({ settings: Object.assign({}, s.settings, { [k]: !s.settings[k] }) }));
  signOut = () => { this.closeSettings(); setTimeout(()=>this.setState({stage:'app',tab:'home',route:null,routeOpen:false}),300); };

  // ---------- pull to refresh ----------
  pullDown = (e) => { const sc=e.currentTarget; if(sc.scrollTop<=0){ this._py=e.clientY; this._pulling=true; } };
  pullMove = (e) => { if(!this._pulling) return; const d=e.clientY-this._py; if(d>0){ this.setState({pulling:true,pullDist:Math.min(90,d*0.55)}); } };
  pullUp = () => { if(!this._pulling) return; this._pulling=false; if(this.state.pullDist>52){ this.setState({refreshing:true,pulling:false,pullDist:46}); setTimeout(()=>this.setState({refreshing:false,pullDist:0}),1200); } else { this.setState({pulling:false,pullDist:0}); } };

  // ---------- drafts swipe ----------
  draftDown = (id) => (e) => { this._sx=e.clientX; this.setState({dragId:id,dragX:0}); try{e.currentTarget.setPointerCapture(e.pointerId);}catch(_){} };
  draftMove = (e) => { if(this.state.dragId==null) return; this.setState({dragX:e.clientX-this._sx}); };
  draftUp = () => { const {dragX,dragId}=this.state; if(dragId==null) return; if(dragX>92) this.approveDraft(dragId)(); else if(dragX<-92) this.skipDraft(dragId)(); this.setState({dragId:null,dragX:0}); };
  approveDraft = (id) => () => { this.setState(s=>({drafts:s.drafts.map(d=>d.id===id?Object.assign({},d,{st:'approved'}):d)})); this.flashToast('Reply sent ✓'); setTimeout(()=>this.setState(s=>({drafts:s.drafts.filter(d=>d.id!==id)})),360); };
  skipDraft = (id) => () => { this.setState(s=>({drafts:s.drafts.map(d=>d.id===id?Object.assign({},d,{st:'dismissed'}):d)})); setTimeout(()=>this.setState(s=>({drafts:s.drafts.filter(d=>d.id!==id)})),360); };
  _restoreDrafts(){ this.setState({ drafts:[
    { id:1, name:'sara_codes', handle:'@sara_codes', initials:'SC', av:'#52525b', intent:'Question', time:'2m', window:'23h 12m left', comment:'do you ship to canada? 👀', draft:"Yes — free shipping over $80, here's the link 🇨🇦", st:'idle' },
    { id:2, name:'ayaan.k', handle:'@ayaan.k', initials:'AK', av:'#3f3f46', intent:'Buyer', time:'6m', window:'22h 40m left', comment:'bhai price kya hai serum ka? 🔥', draft:'Arre ₹1,299 only! DM kar diya link, free shipping above ₹999 ✨', st:'idle' },
    { id:3, name:'meera.rao', handle:'@meera.rao', initials:'MR', av:'#71717a', intent:'Praise', time:'14m', window:'21h 02m left', comment:'obsessed with this reel, the glow is unreal 😍', draft:"You're the sweetest 🥹 it's the niacinamide doing its thing — thank you!", st:'idle' },
    { id:4, name:'studio.luxe', handle:'@studio.luxe', initials:'SL', av:'#52525b', intent:'Brand deal', time:'31m', window:'19h 48m left', comment:'we run a skincare collab program — open to partnering?', draft:'Love that! Sending our rate card + audience deck over now — what timeline are you thinking?', st:'idle' },
  ]}); }

  // ---------- opportunities ----------
  setOppFilter = (k) => () => this.setState({oppFilter:k});
  setStage = (id, stage) => () => { this.setState(s=>({opps:s.opps.map(o=>o.id===id?Object.assign({},o,{stage}):o)})); if(stage===3) this.flashToast('🎉 Deal moved to Won'); };
  advanceOpp = (id) => () => { const o=this.state.opps.find(x=>x.id===id); if(!o) return; const ns=Math.min(3,o.stage+1); this.setState(s=>({opps:s.opps.map(x=>x.id===id?Object.assign({},x,{stage:ns}):x)})); if(ns===3) this.flashToast('🎉 Deal moved to Won'); };

  // ---------- flows / builder ----------
  toggleFlow = (id) => () => this.setState(s=>({flows:s.flows.map(f=>f.id===id?Object.assign({},f,{active:!f.active}):f)}));
  openBuilder = (id) => { this.setState({activeFlowId:id}); this.push('builder'); };
  newFlow = () => { const id=Date.now(); const f={id,name:'Untitled flow',active:false,runs:'Not run yet',trigger:null,steps:[]}; this.setState(s=>({flows:s.flows.concat([f]),activeFlowId:id})); this.push('builder'); };
  renameFlow = (e) => { const v=e.target.value; this.setState(s=>({flows:s.flows.map(f=>f.id===s.activeFlowId?Object.assign({},f,{name:v}):f)})); };
  _curFlow(){ return this.state.flows.find(f=>f.id===this.state.activeFlowId); }
  _updateFlow(fn){ this.setState(s=>({flows:s.flows.map(f=>f.id===s.activeFlowId?fn(f):f)})); }
  _newNode(def){ return {uid:++this._uid,type:def.t,config:Object.assign({},def.defaults||{})}; }

  openPicker = (mode, insertAt) => { this.setState({bsheet:{kind:'picker',mode,insertAt,tab:'action'}}); this._openBsheet(); };
  setPickerTab = (t) => () => this.setState(s=>({bsheet:Object.assign({},s.bsheet,{tab:t})}));
  pickNode = (t) => () => { const def=this.nodeDefs().map[t]; const node=this._newNode(def); const bs=this.state.bsheet;
    if(bs.mode==='trigger'){ this._updateFlow(f=>Object.assign({},f,{trigger:node})); }
    else { const at=bs.insertAt; this._updateFlow(f=>{ const steps=f.steps.slice(); steps.splice(at,0,node); return Object.assign({},f,{steps}); }); }
    if(def.fields && def.fields.length){ const target= bs.mode==='trigger'?'trigger':bs.insertAt; this.setState({bsheet:{kind:'config',target,type:t},chipDraft:''}); }
    else { this._closeBsheet(); }
  };
  openConfig = (target, type) => () => { this.setState({bsheet:{kind:'config',target,type},chipDraft:''}); this._openBsheet(); };
  _curConfig(){ const f=this._curFlow(); const bs=this.state.bsheet; if(!f||!bs) return {}; if(bs.target==='trigger') return (f.trigger&&f.trigger.config)||{}; return (f.steps[bs.target]&&f.steps[bs.target].config)||{}; }
  setField = (key, val) => { const bs=this.state.bsheet; const target=bs.target;
    this._updateFlow(f=>{ if(target==='trigger'){ return Object.assign({},f,{trigger:Object.assign({},f.trigger,{config:Object.assign({},f.trigger.config,{[key]:val})})}); }
      const steps=f.steps.slice(); steps[target]=Object.assign({},steps[target],{config:Object.assign({},steps[target].config,{[key]:val})}); return Object.assign({},f,{steps}); });
  };
  setChipDraft = (e) => this.setState({chipDraft:e.target.value});
  addChip = (key) => () => { const v=this.state.chipDraft.trim(); if(!v) return; const cur=this._curConfig()[key]||[]; this.setField(key,cur.concat([v])); this.setState({chipDraft:''}); };
  removeChip = (key,i) => () => { const cur=(this._curConfig()[key]||[]).slice(); cur.splice(i,1); this.setField(key,cur); };
  stepDragStart = (i) => (e) => { try{ e.currentTarget.setPointerCapture(e.pointerId); }catch(_){}; const card=e.currentTarget.closest('[data-step]'); const list=card?card.parentNode:null; const cards=list?list.querySelectorAll('[data-step]'):[]; this._rowH = cards.length>1 ? Math.abs(cards[1].offsetTop-cards[0].offsetTop) : (card?card.offsetHeight+18:96); this._stepLen = cards.length||1; this._dragY=e.clientY; this.setState({dragIdx:i, dragDy:0}); };
  stepDragMove = (e) => { if(this.state.dragIdx==null) return; this.setState({dragDy:e.clientY-this._dragY}); };
  stepDragEnd = (e) => { try{ e.currentTarget.releasePointerCapture(e.pointerId); }catch(_){}; const i=this.state.dragIdx; if(i==null) return; const rowH=this._rowH||96; const tgt=Math.max(0, Math.min((this._stepLen||1)-1, i+Math.round((this.state.dragDy||0)/rowH))); if(tgt!==i){ this._updateFlow(f=>{ const steps=f.steps.slice(); const m=steps.splice(i,1)[0]; steps.splice(tgt,0,m); return Object.assign({},f,{steps}); }); } this.setState({dragIdx:null, dragDy:0, dropping:true}); setTimeout(()=>this.setState({dropping:false}), 80); };
  deleteStep = (i) => () => this._updateFlow(f=>{ const steps=f.steps.slice(); steps.splice(i,1); return Object.assign({},f,{steps}); });
  moveStep = (i,dir) => () => this._updateFlow(f=>{ const steps=f.steps.slice(); const j=i+dir; if(j<0||j>=steps.length) return f; const tmp=steps[i]; steps[i]=steps[j]; steps[j]=tmp; return Object.assign({},f,{steps}); });
  runTest = () => { this.setState({bsheet:{kind:'test'}}); this._openBsheet(); };
  _openBsheet(){ this.setState({bsheetMounted:true,bsheetClosing:false}); }
  _closeBsheet(){ this.setState({bsheetClosing:true}); setTimeout(()=>this.setState({bsheetMounted:false,bsheet:null,bsheetClosing:false}),300); }
  closeBsheet = () => this._closeBsheet();

  // ---------- thread ----------
  _seedThread(c){
    if(c.intent==='Question'||c.handle==='@sara_codes') return [ {from:'them',text:'hey! love the new serum drop 🙌'},{from:'them',text:'do you ship to canada? 👀'},{from:'ai',text:"Yes — free shipping over $80, here's the link 🇨🇦", ai:true} ];
    if(c.handle==='@ayaan.k') return [ {from:'them',text:'bhai price kya hai serum ka? 🔥'},{from:'ai',text:'Arre ₹1,299 only! DM kar diya link, free shipping above ₹999 ✨', ai:true},{from:'them',text:'done ordered 🙌'} ];
    return [ {from:'them',text:c.last||'hi!'} ];
  }
  openThread = (c) => () => { const msgs=this._seedThread(c); const last=msgs[msgs.length-1]; const suggest=last.from==='them';
    this.setState({ activeThread:{ name:c.name, handle:c.handle, initials:c.initials, av:c.av||'#3f3f46', msgs, typing:false, suggest, suggestText: suggest?'Thanks so much! Let me get you sorted 💛':'' } }); this.push('thread'); };
  onCompose = (e) => this.setState({composer:e.target.value});
  sendMsg = () => { const t=this.state.composer.trim(); if(!t||!this.state.activeThread) return; const at=this.state.activeThread;
    this.setState({ activeThread:Object.assign({},at,{msgs:at.msgs.concat([{from:'me',text:t}]),typing:true,suggest:false}), composer:'' });
    setTimeout(()=>{ const a=this.state.activeThread; if(!a) return; this.setState({activeThread:Object.assign({},a,{typing:false,msgs:a.msgs.concat([{from:'them',text:'amazing, thank you! 🙌'}])})}); },1400); };
  sendSuggest = () => { const at=this.state.activeThread; if(!at) return; this.setState({activeThread:Object.assign({},at,{suggest:false,msgs:at.msgs.concat([{from:'me',text:at.suggestText}])})}); this.flashToast('Reply sent ✓'); };

  // ---------- storefront / catalog ----------
  openStorefront = () => { this.setState({sfProduct:null}); this.push('storefront'); };
  openCatalog = () => this.push('catalog');
  openSfProduct = (id) => () => { this.setState({sfProduct:id}); };
  sfBack = () => this.setState({sfProduct:null});
  previewInShop = (id) => () => { this.setState({sfProduct:id}); this.push('storefront'); };
  toggleAvail = (id) => () => this.setState(s=>({products:s.products.map(p=>p.id===id?Object.assign({},p,{available:!p.available}):p)}));
  toggleFeatured = (id) => () => this.setState(s=>({products:s.products.map(p=>p.id===id?Object.assign({},p,{featured:!p.featured}):p)}));
  copyUrl = () => this.flashToast('Link copied ✓');
  setSf = (k,v) => () => this.setState(s=>({storefront:Object.assign({},s.storefront,{[k]:v})}));
  setSfVal = (k) => (e) => this.setState(s=>({storefront:Object.assign({},s.storefront,{[k]:e.target.value})}));
  toggleSf = (k) => () => this.setState(s=>({storefront:Object.assign({},s.storefront,{[k]:!s.storefront[k]})}));
  openCustomize = () => this.setState({csheetMounted:true,csheetClosing:false});
  closeCustomize = () => { this.setState({csheetClosing:true}); setTimeout(()=>this.setState({csheetMounted:false,csheetClosing:false}),300); };
  // ---------- add product ----------
  openAddProduct = () => { this.setState({ npName:'', npPrice:'', npSubtitle:'', npDesc:'', npAvailable:true }); this.push('addProduct'); };
  setNp = (k) => (e) => this.setState({ [k]: e.target.value });
  toggleNpAvail = () => this.setState(s=>({ npAvailable:!s.npAvailable }));
  saveProduct = () => { const n=this.state.npName.trim(); if(!n){ this.flashToast('Add a product name'); return; }
    const mono=(n.replace(/[^A-Za-z]/g,'').slice(0,2)||'PR').toUpperCase(); const id=Date.now();
    const p={ id, title:n, subtitle:this.state.npSubtitle.trim()||'New product', price:this.state.npPrice.trim()||'DM for price', mono, available:this.state.npAvailable, featured:false, cta:true, desc:this.state.npDesc.trim()||'A new product in the catalog.' };
    this.setState(s=>({ products:s.products.concat([p]) })); this.flashToast('Product added ✓'); this.setState({route:'catalog'}); };
  addProduct = () => this.openAddProduct();

  // ---------- store orders + insights ----------
  openOrders = () => this.push('orders');
  openStoreStats = () => this.push('storeStats');
  advanceOrder = (id) => () => { const o=this.state.orders.find(x=>x.id===id); if(!o||o.status==='shipped') return; const nx=o.status==='new'?'paid':'shipped';
    this.setState(s=>({ orders:s.orders.map(x=>x.id===id?Object.assign({},x,{status:nx}):x) })); this.flashToast(nx==='paid'?'Marked paid ✓':'Marked shipped ✓'); };

  // ---------- automation templates ----------
  flowTemplates(){ if(this._ft) return this._ft; this._ft=[
    { id:'comment_dm', name:'Comment → DM link', icon:'comment', desc:'When someone comments a keyword, DM them your link privately.', trigger:{type:'comment',config:{scope:'All posts',kw:['link','price']}}, steps:[ {type:'private_reply',config:{text:'Sent it to your DMs 💌'}}, {type:'send_link',config:{text:"Here's the link 👉",url:'dslabs.in/serum'}} ] },
    { id:'welcome_dm', name:'Welcome new DMs', icon:'dm', desc:'Greet first-time DMs in your brand voice, automatically.', trigger:{type:'dm',config:{kw:[]}}, steps:[ {type:'first_time',config:{}}, {type:'ai_reply',config:{tone:'Warm'}} ] },
    { id:'link_delivery', name:'Link delivery', icon:'link2', desc:'Anyone who asks for the link gets it instantly in their DMs.', trigger:{type:'dm',config:{kw:['link','buy','shop']}}, steps:[ {type:'send_link',config:{text:'Here you go 👉',url:'dslabs.in'}}, {type:'add_tag',config:{tag:'link-sent'}} ] },
    { id:'lead_capture', name:'Lead form capture', icon:'mail', desc:'Qualify buyers, then capture their email for 10% off.', trigger:{type:'dm',config:{kw:['price','cost','order']}}, steps:[ {type:'intent',config:{val:'Buyer'}}, {type:'ask_email',config:{text:'Drop your email for 10% off 👇'}}, {type:'set_status',config:{val:'Hot'}} ] },
    { id:'story_reply', name:'Story-reply autoresponder', icon:'reply', desc:'Auto-thank anyone who replies to your story.', trigger:{type:'story_reply',config:{}}, steps:[ {type:'send_dm',config:{text:'Thanks for the love! 🥹'}}, {type:'add_tag',config:{tag:'advocate'}} ] },
  ]; return this._ft; }
  openTemplates = () => this.push('templates');
  toggleAutoMenu = () => this.setState({autoMenu:!this.state.autoMenu});
  pickTemplate = () => { this.setState({autoMenu:false}); this.push('templates'); };
  pickScratch = () => { this.setState({autoMenu:false}); this.newFlow(); };
  useTemplate = (tid) => () => { const t=this.flowTemplates().find(x=>x.id===tid); if(!t) return; const id=Date.now();
    const trigger=t.trigger?{uid:++this._uid,type:t.trigger.type,config:Object.assign({},t.trigger.config)}:null;
    const steps=t.steps.map(st=>({uid:++this._uid,type:st.type,config:Object.assign({},st.config)}));
    const f={ id, name:t.name, active:false, runs:'Draft · from template', trigger, steps };
    this.setState(s=>({ flows:s.flows.concat([f]), activeFlowId:id, route:'builder' })); this.flashToast('Template added ✓'); };

  // ---------- guard center ----------
  openGuard = () => this.push('guard');
  setGuardSeg = (k) => () => this.setState({ guardSeg:k });
  _dropFlagged(id){ this.setState(s=>({ flagged:s.flagged.map(f=>f.id===id?Object.assign({},f,{st:'gone'}):f) })); setTimeout(()=>this.setState(s=>({ flagged:s.flagged.filter(f=>f.id!==id) })),300); }
  hideFlagged = (id) => () => { this._dropFlagged(id); this.flashToast('Comment hidden ✓'); };
  allowFlagged = (id) => () => { this._dropFlagged(id); this.flashToast('Marked safe'); };
  blockFlagged = (id) => () => { const f=this.state.flagged.find(x=>x.id===id); if(!f) return;
    const entry={ userId:'u_'+id, username:f.handle, initials:f.initials, reason: f.category==='hate'?'Hate speech':f.category==='spam'?'Spam / f4f':f.category==='sexual'?'Sexual content':'Troll / abuse', ts:'just now' };
    this.setState(s=>({ blocklist:[entry].concat(s.blocklist) })); this._dropFlagged(id); this.flashToast(f.handle+' blocked'); };
  toggleGuardRule = (k) => () => this.setState(s=>({ guardRules:Object.assign({},s.guardRules,{[k]:!s.guardRules[k]}) }));
  setKwDraft = (e) => this.setState({ kwDraft:e.target.value });
  addBlockKw = () => { const v=this.state.kwDraft.trim(); if(!v) return; this.setState(s=>({ blockKeywords:s.blockKeywords.concat([v]), kwDraft:'' })); };
  addBlockKwKey = (e) => { if(e.key==='Enter'){ e.preventDefault(); this.addBlockKw(); } };
  removeBlockKw = (i) => () => this.setState(s=>{ const a=s.blockKeywords.slice(); a.splice(i,1); return { blockKeywords:a }; });
  unblock = (userId) => () => { this.setState(s=>({ blocklist:s.blocklist.filter(b=>b.userId!==userId) })); this.flashToast('Unblocked'); };

  // ---------- test builder ----------
  _buildTest(f,defs){ if(!f) return {title:'',msgs:[]}; const msgs=[]; const td=f.trigger?defs.map[f.trigger.type]:null;
    const tt=f.trigger&&f.trigger.config.kw&&f.trigger.config.kw.length? f.trigger.config.kw[0] : (td&&td.t==='comment'?'love this! where to buy? 😍':'hey! 👋');
    msgs.push({kind:'bubble',who:'them',text:tt,tag:td?td.label:'Trigger'});
    f.steps.forEach(st=>{ const d=defs.map[st.type]; const c=st.config;
      if(st.type==='private_reply'||st.type==='send_dm') msgs.push({kind:'bubble',who:'ai',text:c.text||d.sum(c)});
      else if(st.type==='send_link') msgs.push({kind:'bubble',who:'ai',text:((c.text||'Here you go')+' '+(c.url||'')).trim()});
      else if(st.type==='ai_reply') msgs.push({kind:'bubble',who:'ai',text:'Thanks so much! 💛 ('+(c.tone||'Warm')+' AI reply)',tag:'Mira drafted'});
      else if(st.type==='quick_replies') msgs.push({kind:'bubble',who:'ai',text:'',btns:(c.btns&&c.btns.length?c.btns:['Option A','Option B'])});
      else if(st.type==='ask_email') msgs.push({kind:'bubble',who:'ai',text:c.text||'Drop your email 👇',btns:['📧 Share email']});
      else if(st.type==='ask_phone') msgs.push({kind:'bubble',who:'ai',text:c.text||'Share your number',btns:['📱 Share number']});
      else if(st.type==='carousel') msgs.push({kind:'bubble',who:'ai',text:'',carousel:true});
      else msgs.push({kind:'note',text:d.label+' — '+d.sum(c)});
    });
    return { title:f.name, msgs };
  }

  // ---------- render ----------
  renderVals(){
    const s=this.state, A='var(--accent)', SUB='var(--text-subtle)', PUR='var(--purple)', WARM='var(--st-warm)';
    const defs=this.nodeDefs();
    const greet='Good morning';

    const modeDefs=[ {k:'shadow',label:'Shadow',sub:'draft only'},{k:'assisted',label:'Assisted',sub:'you approve'},{k:'auto',label:'Auto',sub:'send now'} ];
    const modes=modeDefs.map(m=>{ const on=s.replyMode===m.k; return { label:m.label, sub:m.sub, set:this.setReplyMode(m.k), bg:on?'var(--bg-elev)':'transparent', fg:on?'var(--text)':'var(--text-muted)', sh:on?'var(--shadow-card)':'none' }; });

    const todayDefs=[ {label:'New comments',value:24,col:SUB},{label:'Auto-replied',value:18,col:'var(--st-done)'},{label:'Pending',value:s.drafts.length,col:A},{label:'Needs you',value:2,col:WARM},{label:"Links DM'd",value:11,col:SUB} ];
    const today=todayDefs.map(c=>({label:c.label,value:c.value,col:c.col,vcol:c.label==='Pending'&&c.value>0?A:c.label==='Needs you'&&c.value>0?WARM:'var(--text)'}));
    const todayRows=today.map((c,i)=>Object.assign({},c,{divider:i>0}));
    const modeDescs={ shadow:'Mira drafts replies silently in the background — nothing is sent.', assisted:'Mira drafts every reply in your voice — you approve before it sends.', auto:'Mira sends high-confidence replies instantly, on its own.' };
    const modeDesc=modeDescs[s.replyMode]||modeDescs.assisted;
    const dash={ coverage:87, replies:'1,240', comments:'1,602', facts:48, sent:64, cap:180, capPct:Math.round(64/180*100)+'%', today,
      activity:"Today, Mira saw 24 new comments, auto-replied to 18, drafted "+s.drafts.length+" for you and DM'd 11 links — flagging the rest for your eyes." };

    const jumpDefs=[
      {label:'Contacts',meta:s.contacts.length+' people',go:()=>this.push('contacts'),icon:this.nodeIcon('user',17)},
      {label:'Analytics',meta:'+12% this week',go:()=>this.push('analytics'),icon:this.ic('<path d="M4 19V5M4 19h16"/><path d="M8 16v-4M13 16V8M18 16v-6"/>',17)},
      {label:'Guard Center',meta:s.flagged.length+' flagged',go:()=>this.push('guard'),icon:this.ic('<path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3Z"/>',17)},
    ];
    const jumps=jumpDefs.map((j,i)=>Object.assign({},j,{divider:i>0}));

    const navDefs=[
      {k:'home',go:this.setTab('home'),p:'<path d="M4 11.4 12 4.4l8 7"/><path d="M6.4 10.4V18.5a1 1 0 0 0 1 1h9.2a1 1 0 0 0 1-1v-8.1"/>'},
      {k:'opps',go:this.setTab('opps'),p:'<path d="M4 20V4.5M4 20h16"/><path d="M8 17v-5M13 17V8M18 17v-8"/>'},
      {k:'inbox',center:true,go:this.setTab('inbox'),p:'<path d="M5 4.5h14a2.2 2.2 0 0 1 2.2 2.2v7.4A2.2 2.2 0 0 1 19 16.3h-7.2L7.4 20v-3.7H5A2.2 2.2 0 0 1 2.8 14V6.7A2.2 2.2 0 0 1 5 4.5Z"/>'},
      {k:'auto',go:this.setTab('auto'),p:'<circle cx="6" cy="6" r="2.3"/><circle cx="18" cy="18" r="2.3"/><circle cx="18" cy="6" r="2.3"/><path d="M8.3 6H15M18 8.3v7.4M16.1 16.1 9 8.4"/>'},
      {k:'profile',go:this.openSettings,p:'<circle cx="12" cy="12" r="8.6"/><circle cx="12" cy="10" r="3"/><path d="M6.8 18.4a5.8 5.8 0 0 1 10.4 0"/>'},
    ];
    const tabLabels={home:'Home',opps:'Opportunities',inbox:'Inbox',auto:'Flows',profile:'You'};
    const tabs=navDefs.map(d=>{
      const active = d.k==='profile'? s.sheetMounted : s.tab===d.k;
      return { go:d.go, label:tabLabels[d.k], icon:this.icN(d.p,23),
        btnFlex: active?'0 1 auto':'1 1 0',
        btnBg: active?'var(--text)':'transparent',
        btnFg: active?'var(--bg)':'var(--text-subtle)',
        btnPad: active?'0 15px':'0',
        lblMax: active?'90px':'0', lblOp: active?'1':'0',
        badge: d.k==='inbox' && s.drafts.length>0 }; });

    const tagColors={ Question:['var(--bg-inset)','var(--text-muted)'], Buyer:['color-mix(in srgb,var(--st-warm) 16%,transparent)','var(--st-warm)'], Praise:['color-mix(in srgb,var(--st-done) 15%,transparent)','var(--st-done)'], 'Brand deal':['color-mix(in srgb,var(--purple) 16%,transparent)','var(--purple)'] };
    const drafts=s.drafts.map(d=>{ let tf='translateX(0)',tr='transform .28s cubic-bezier(.32,.72,0,1)';
      if(d.st==='approved') tf='translateX(115%)'; else if(d.st==='dismissed') tf='translateX(-115%)'; else if(s.dragId===d.id){ tf='translateX('+s.dragX+'px)'; tr='none'; }
      const dx=s.dragId===d.id?s.dragX:0; const tc=tagColors[d.intent]||tagColors.Question;
      return Object.assign({},d,{ tf,tr, revR:Math.max(0,Math.min(1,dx/92)).toFixed(2), revL:Math.max(0,Math.min(1,-dx/92)).toFixed(2), tagbg:tc[0], tagfg:tc[1],
        down:this.draftDown(d.id), move:this.draftMove, up:this.draftUp, approve:this.approveDraft(d.id), skip:this.skipDraft(d.id),
        open:this.openThread({name:d.name,handle:d.handle,initials:d.initials,av:d.av,intent:d.intent,last:d.comment}) }); });

    // opportunities feed
    const oStages=['New','Review','Negotiating','Won'];
    const cnt=[0,1,2,3].map(i=>s.opps.filter(o=>o.stage===i).length);
    const oppChips=[{k:'all',label:'All',n:s.opps.length}].concat(oStages.map((nm,i)=>({k:i,label:nm,n:cnt[i]}))).map(c=>{ const on=s.oppFilter===c.k; return { label:c.label, n:c.n, set:this.setOppFilter(c.k), bg:on?'var(--text)':'var(--bg-elev)', fg:on?'#fff':'var(--text-muted)', bd:on?'var(--text)':'var(--border)' }; });
    const RING=2*Math.PI*17;
    const feed=s.opps.filter(o=>s.oppFilter==='all'||o.stage===s.oppFilter).slice().sort((a,b)=>(a.stage-b.stage)||(b.conf-a.conf)).map(o=>{
      const confcol=o.conf>=85?'var(--st-done)':o.conf>=70?'var(--text-muted)':'var(--text-subtle)';
      const stages=oStages.map((nm,i)=>{ const done=i<o.stage,on=i===o.stage; return { label:nm, set:this.setStage(o.id,i),
        dot: (done||on)?(o.stage===3&&i===3?'var(--st-done)':A):'var(--bg-elev)', ring:(done||on)?(o.stage===3&&i===3?'var(--st-done)':A):'var(--border-strong)', lcol:on?'var(--text)':done?'var(--text-muted)':SUB }; });
      const ctaLabel=o.stage===2?'Mark won':'Advance to '+oStages[o.stage+1];
      return { initials:o.initials, av:o.conf>=90?'#52525b':o.conf>=80?'#3f3f46':'#71717a', name:o.name, handle:o.handle, type:o.type, value:o.value, conf:o.conf, confcol,
        ringC:RING.toFixed(1), ringOff:(RING*(1-o.conf/100)).toFixed(1), fillW:(o.stage/3*84)+'%', stages,
        hasCta:o.stage<3, won:o.stage===3, cta:this.advanceOpp(o.id), ctaLabel, ctaBg:o.stage===2?'var(--st-done)':'var(--text)', ctaFg:'#fff' };
    });
    const wonCount=s.opps.filter(o=>o.stage===3).length;
    const oppSummary={ pipeline:'₹4.8L', won:String(wonCount), rate:'68%' };
    const agentAv=['#3f3f46','#52525b','#6b6b70','#71717a'];
    const agents=[ {name:'Scout', role:'Sourcing new leads', stat:'12 found today', init:'SC'},
      {name:'Sage', role:'Scoring buyer intent', stat:'7 qualified', init:'SG'},
      {name:'Closer', role:'Advancing warm deals', stat:'3 moved up', init:'CL'},
      {name:'Echo', role:'Following up on time', stat:'5 nudged', init:'EC'} ].map((a,i)=>Object.assign({},a,{av:agentAv[i%agentAv.length]}));

    // flows list
    const catCol={trigger:[WARM,'color-mix(in srgb,var(--st-warm) 14%,transparent)'], condition:[PUR,'color-mix(in srgb,var(--purple) 14%,transparent)'], action:[A,'var(--accent-soft)'], more:[SUB,'var(--bg-inset)']};
    const flows=s.flows.map(f=>{ const td=f.trigger?defs.map[f.trigger.type]:null;
      const chipDefs=[{label:td?td.label:'No trigger',cat:'trigger'}].concat(f.steps.slice(0,3).map(st=>({label:defs.map[st.type].label,cat:defs.map[st.type].cat}))); if(f.steps.length>3) chipDefs.push({label:'+'+(f.steps.length-3),cat:'more'});
      const chips=chipDefs.map((c,i)=>{ const cc=catCol[c.cat]||catCol.action; return { label:c.label, fg:cc[0], bg:cc[1], arrow:i<chipDefs.length-1 }; });
      return { id:f.id, name:f.name, runs:f.runs, icon:this.nodeIcon(td?td.icon:'spark',20), iconbg:f.active?'var(--accent-soft)':'var(--bg-inset)', iconfg:f.active?'var(--accent-deep)':SUB,
        runDot:f.active?'var(--st-done)':SUB, chips, statusLabel:f.active?'Active':'Inactive', statusCol:f.active?'var(--st-done)':SUB,
        trackbg:f.active?'var(--text)':'var(--border-strong)', knob:f.active?'translateX(19px)':'translateX(0)', toggle:this.toggleFlow(f.id), open:()=>this.openBuilder(f.id) }; });
    const flowsActive=s.flows.filter(f=>f.active).length;

    // builder
    const cf=this._curFlow();
    let builder={steps:[],hasTrigger:false,noTrigger:true,name:'',runs:'',runDot:SUB,trackbg:'var(--border-strong)',knob:'translateX(0)'};
    if(cf){ const td=cf.trigger?defs.map[cf.trigger.type]:null;
      const di=s.dragIdx, ddy=s.dragDy||0, rowH=this._rowH||96;
      const dtgt = di==null? null : Math.max(0, Math.min(cf.steps.length-1, di+Math.round(ddy/rowH)));
      const steps=cf.steps.map((st,i)=>{ const d=defs.map[st.type]; const cond=d.cat==='condition'; const col=cond?PUR:A; const drag=di===i;
        let ty=0, z=1; if(di!=null){ if(drag){ ty=ddy; z=20; } else if(di<dtgt && i>di && i<=dtgt){ ty=-rowH; } else if(di>dtgt && i>=dtgt && i<di){ ty=rowH; } }
        return { label:d.label, summary:d.sum(st.config), icon:this.nodeIcon(d.icon,18), col,
          iconbg:cond?'color-mix(in srgb,var(--purple) 14%,transparent)':'var(--accent-soft)', iconfg:cond?PUR:'var(--accent-deep)',
          open:this.openConfig(i,st.type), del:this.deleteStep(i), insertBefore:()=>this.openPicker('step',i),
          dragStart:this.stepDragStart(i), dragMove:this.stepDragMove, dragEnd:this.stepDragEnd,
          shadow: drag?'0 18px 40px rgba(60,50,95,.24),inset 0 1px 0 rgba(255,255,255,.6)':'0 1px 2px rgba(24,24,27,.04),0 10px 26px rgba(60,50,95,.07),inset 0 1px 0 rgba(255,255,255,.6)',
          tf: drag?'translateY('+ty+'px) scale(1.03)':'translateY('+ty+'px)', z: String(z),
          trans: (drag||s.dropping)?'box-shadow .18s ease':'box-shadow .18s ease, transform .2s cubic-bezier(.2,0,0,1)',
          grab: drag?'grabbing':'grab', connOp: di==null?'1':'0' }; });
      builder={ name:cf.name, runs:cf.runs, runDot:cf.active?'var(--st-done)':SUB, rename:this.renameFlow,
        hasTrigger:!!cf.trigger, noTrigger:!cf.trigger,
        trigger: cf.trigger?{ label:td.label, sub:td.sub, summary:td.sum(cf.trigger.config), icon:this.nodeIcon(td.icon,20), open:this.openConfig('trigger',cf.trigger.type), swapTrigger:()=>this.openPicker('trigger',-1) }:null,
        addTrigger:()=>this.openPicker('trigger',-1), steps, hasSteps:cf.steps.length>0, addStep:()=>this.openPicker('step',cf.steps.length),
        toggleActive:this.toggleFlow(cf.id), test:this.runTest, trackbg:cf.active?'var(--text)':'var(--border-strong)', knob:cf.active?'translateX(19px)':'translateX(0)' };
    }

    // builder sheet
    const bs=s.bsheet;
    let picker={nodes:[]}, config={fields:[]}, test={msgs:[]};
    const catColor=(cat)=> cat==='trigger'?[WARM,'color-mix(in srgb,var(--st-warm) 15%,transparent)']: cat==='condition'?[PUR,'color-mix(in srgb,var(--purple) 15%,transparent)']:[A,'var(--accent-soft)'];
    if(bs&&bs.kind==='picker'){ const isTrig=bs.mode==='trigger';
      const PDESC={contains:'Run only if the message matches',is_follower:'Check if they follow you',first_time:'Only their first time reaching out',window:'Gate on the 24-hour reply window',intent:'Branch on what AI reads they want',business_hours:'Only during your open hours',split:'Randomly send down two paths',private_reply:'Reply privately to the comment',send_dm:'Send them a direct message',send_link:'Drop a link in the DM',carousel:'Show a swipeable product carousel',quick_replies:'Show tappable reply buttons',ask_email:'Capture their email (consent logged)',ask_phone:'Capture their phone (consent logged)',ai_reply:'Let AI draft in your brand voice',add_tag:'Tag the contact in your CRM',set_status:'Set their lead status',assign:'Notify you or hand to an agent',wait:'Pause before the next step',hide_comment:'Hide the comment from the post',react:'React to their message',optin_topic:'Add them to a marketing topic',end:'Stop the automation here'};
      const mkNode=d=>{ const cc=catColor(d.cat); return { label:d.label, desc:isTrig?(d.sub||''):(PDESC[d.t]||d.sub||''), icon:this.nodeIcon(d.icon,18), pick:this.pickNode(d.t), col:cc[0], bg:cc[1] }; };
      const groups= isTrig? [{title:'', hasTitle:false, nodes:defs.triggers.map(mkNode)}]
        : [{title:'Conditions', hasTitle:true, nodes:defs.conditions.map(mkNode)},{title:'Actions', hasTitle:true, nodes:defs.actions.map(mkNode)}];
      picker={ title:isTrig?'Choose a trigger':'Add a step', groups };
    }
    if(bs&&bs.kind==='config'){ const d=defs.map[bs.type]; const cfg=this._curConfig(); const cc=catColor(d.cat);
      config={ title:d.label, sub:d.sub||'', icon:this.nodeIcon(d.icon,18), col:cc[0], bg:cc[1], empty:d.fields.length===0, emptyText:d.sum(cfg)+'. No settings needed — it just works.',
        fields:d.fields.map(f=>{ const val=cfg[f.key]; const selVal=(f.kind==='select')?(val||f.opts[0]):val;
          return { label:f.label, ph:f.ph||'', unit:f.unit||'', isText:f.kind==='text', isArea:f.kind==='area', isChips:f.kind==='chips', isSelect:f.kind==='select', isNumber:f.kind==='number',
            value: f.kind==='number'?(val==null?'':val):(typeof val==='string'?val:''),
            set:(e)=>this.setField(f.key, f.kind==='number'?(parseInt(e.target.value)||0):e.target.value),
            chips:(Array.isArray(val)?val:[]).map((c,i)=>({label:c, remove:this.removeChip(f.key,i)})), addChip:this.addChip(f.key), addChipKey:(e)=>{ if(e.key==='Enter'){ e.preventDefault(); this.addChip(f.key)(); } },
            opts:(f.opts||[]).map(o=>{ const on=selVal===o; return { label:o, set:()=>this.setField(f.key,o), bg:on?'var(--text)':'var(--bg-elev)', fg:on?'#fff':'var(--text-muted)', bd:on?'var(--text)':'var(--border)' }; }) };
        }) };
    }
    if(bs&&bs.kind==='test'){ const t=this._buildTest(cf,defs);
      test={ title:t.title, msgs:t.msgs.map(m=>{ if(m.kind==='note') return {isNote:true,isBubble:false,text:m.text};
        const me=m.who==='ai'; return { isNote:false,isBubble:true, justify:me?'flex-end':'flex-start', align:me?'flex-end':'flex-start',
          hasText:!!m.text, text:m.text, tag:!!m.tag, tagText:m.tag||'', bg:me?A:'var(--bubble-them)', fg:me?'#fff':'var(--bubble-them-fg)',
          corner:me?'border-bottom-right-radius:5px;':'border-bottom-left-radius:5px;',
          hasBtns:!!m.btns, btns:m.btns||[], hasCarousel:!!m.carousel, cards:m.carousel?s.products.slice(0,3).map(p=>({mono:p.mono,title:p.title,price:p.price})):[] }; }) };
    }

    const stColors={ hot:['color-mix(in srgb,var(--st-blocked) 14%,transparent)','var(--st-blocked)'], warm:['color-mix(in srgb,var(--st-warm) 16%,transparent)','var(--st-warm)'], cold:['var(--bg-inset)',SUB], vip:['color-mix(in srgb,var(--purple) 15%,transparent)','var(--purple)'], customer:['color-mix(in srgb,var(--st-done) 14%,transparent)','var(--st-done)'] };
