<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<script src="./support.js"></script>
</head>
<body>
<x-dc>
<helmet>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-frame:radial-gradient(150% 100% at 100% 100%,#f6f5fc 0%,#fbf6f6 45%,#ffffff 82%); --bg:#ffffff; --bg-elev:#ffffff; --bg-sidebar:#fafafa; --bg-inset:#f4f4f5;
    --border:#ebebed; --border-strong:#d4d4d8; --text:#18181b; --text-muted:#6b6b70; --text-subtle:#9c9ca1;
    --accent:#5A5FE0; --accent-fg:#ffffff; --accent-soft:#ECEDFC; --accent-deep:#4346C0; --glass-smoke-bg:rgba(236,236,245,.45); --glass-light-bg:rgba(255,255,255,.72); --glass-border:rgba(255,255,255,.55); --glass-shadow:0 8px 24px rgba(60,50,95,.12); --glass-highlight:inset 0 1px 0 rgba(255,255,255,.55); --glass-text:#2C2C3C; --glass-blur:16px;
    --st-progress:#b8791c; --st-done:#1f9d6b; --st-blocked:#d14343; --st-warm:#b8791c; --purple:#6b6b70;
    --bubble-them:#f4f4f5; --bubble-them-fg:#18181b;
    --shadow-card:0 1px 2px rgba(24,24,27,.05); --shadow-pop:0 12px 32px rgba(24,24,27,.10),0 4px 16px rgba(24,24,27,.08); --shadow-soft:0 4px 16px rgba(24,24,27,.08);
  }
    *{margin:0;padding:0;box-sizing:border-box;}
  .glass-smoke{background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border:.5px solid var(--glass-border);box-shadow:var(--glass-shadow),var(--glass-highlight);color:var(--glass-text);transition:transform .15s ease,background .15s ease;}.glass-light{background:var(--glass-light-bg);backdrop-filter:blur(14px) saturate(130%);-webkit-backdrop-filter:blur(14px) saturate(130%);border:.5px solid rgba(255,255,255,.7);box-shadow:0 6px 18px rgba(60,50,95,.10),inset 0 1px 0 rgba(255,255,255,.7);color:var(--glass-text);transition:transform .15s ease,background .15s ease;}.glass-smoke:active,.glass-light:active{transform:scale(.98);}@supports not ((backdrop-filter:blur(1px)) or (-webkit-backdrop-filter:blur(1px))){.glass-smoke{background:rgba(240,240,247,.92);}.glass-light{background:rgba(255,255,255,.95);}}:focus-visible{outline:2px solid var(--accent);outline-offset:2px;}body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'SF Pro Text',system-ui,sans-serif;-webkit-font-smoothing:antialiased;}
  ::-webkit-scrollbar{width:0;height:0;display:none;}
  .scroll{scrollbar-width:none;-ms-overflow-style:none;}
  @keyframes spin{to{transform:rotate(360deg);}}
  @keyframes pop{0%{transform:scale(.85);opacity:0;}100%{transform:scale(1);opacity:1;}}
  @keyframes slideup{from{transform:translateY(14px);opacity:0;}to{transform:translateY(0);opacity:1;}}
  @keyframes dotp{0%,80%,100%{opacity:.25;transform:translateY(0);}40%{opacity:1;transform:translateY(-3px);}}
  @keyframes glow{0%,100%{box-shadow:0 0 0 0 color-mix(in srgb,var(--accent) 55%,transparent);}50%{box-shadow:0 0 0 7px color-mix(in srgb,var(--accent) 0%,transparent);}}
  @keyframes msgin{from{transform:translateY(8px) scale(.96);opacity:0;}to{transform:translateY(0) scale(1);opacity:1;}}
  @keyframes rayspin{to{transform:rotate(360deg);}}
  @keyframes rin{from{transform:translateX(100%);}to{transform:translateX(0);}}
  @keyframes rout{from{transform:translateX(0);}to{transform:translateX(100%);}}
  @keyframes shin{from{transform:translateY(100%);}to{transform:translateY(0);}}
  @keyframes shout{from{transform:translateY(0);}to{transform:translateY(100%);}}
  @keyframes fin{from{opacity:0;}to{opacity:1;}}
  @keyframes fout{from{opacity:1;}to{opacity:0;}}
</style>
</helmet>

<div style="min-height:100vh;width:100%;display:flex;align-items:center;justify-content:center;padding:24px;background:radial-gradient(120% 120% at 50% 0%,#23252e 0%,#141519 55%,#0c0d10 100%);font-family:'Inter',-apple-system,BlinkMacSystemFont,'SF Pro Text',system-ui,sans-serif;">

  <div data-theme="{{ theme }}" style="position:relative;width:390px;height:844px;border-radius:54px;background:#000;padding:13px;box-shadow:0 0 0 2px #2a2a2e,0 30px 80px -20px rgba(0,0,0,.7),0 12px 30px -10px rgba(0,0,0,.6);flex-shrink:0;">
    <div style="position:absolute;inset:0;border-radius:54px;box-shadow:inset 0 0 0 1px rgba(255,255,255,.06);pointer-events:none;z-index:60;"></div>

    <div style="position:relative;width:100%;height:100%;border-radius:42px;overflow:hidden;background:var(--bg-frame);color:var(--text);">

      <!-- ===== STATUS BAR ===== -->
      <div style="position:absolute;top:0;left:0;right:0;height:52px;z-index:50;display:flex;align-items:flex-end;justify-content:space-between;padding:0 30px 8px;pointer-events:none;">
        <div style="font-size:15px;font-weight:500;letter-spacing:-.02em;color:var(--text);">9:41</div>
        <div style="display:flex;align-items:center;gap:7px;">
          <svg width="18" height="12" viewBox="0 0 18 12" fill="var(--text)"><rect x="0" y="7" width="3" height="5" rx="1"/><rect x="5" y="4.5" width="3" height="7.5" rx="1"/><rect x="10" y="2" width="3" height="10" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1"/></svg>
          <svg width="17" height="12" viewBox="0 0 17 12" fill="var(--text)"><path d="M8.5 2.4c2.3 0 4.4.9 6 2.4l1.4-1.5A11 11 0 0 0 8.5.3 11 11 0 0 0 1 3.3l1.5 1.5a8.6 8.6 0 0 1 6-2.4Zm0 4c1.2 0 2.3.5 3.1 1.3l1.4-1.5a7 7 0 0 0-9 0l1.4 1.5A4.5 4.5 0 0 1 8.5 6.4Zm0 3.9 2-2.1a3 3 0 0 0-4 0l2 2.1Z"/></svg>
          <div style="display:flex;align-items:center;gap:2px;"><div style="width:23px;height:12px;border:1px solid var(--text);opacity:.5;border-radius:3px;display:flex;align-items:center;padding:1.5px;"><div style="width:70%;height:100%;background:var(--text);border-radius:1.5px;"></div></div><div style="width:1.5px;height:4px;background:var(--text);opacity:.4;border-radius:2px;"></div></div>
        </div>
      </div>

      <!-- ===== PRE-APP FLOW ===== -->
      <sc-if value="{{ showPreApp }}" hint-placeholder-val="{{ true }}">
      <div style="position:absolute;inset:0;z-index:40;background:var(--bg-frame);overflow:hidden;">
        <div style="position:absolute;width:520px;height:520px;top:-14%;right:-22%;border-radius:50%;background:radial-gradient(circle,color-mix(in srgb,var(--accent) 22%,transparent),transparent 68%);pointer-events:none;"></div>

        <!-- SIGN IN -->
        <sc-if value="{{ stageSignin }}" hint-placeholder-val="{{ true }}">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 36px;text-align:center;">
          <div style="width:88px;height:88px;border-radius:24px;background:linear-gradient(150deg,var(--accent),var(--accent-deep));display:flex;align-items:center;justify-content:center;box-shadow:0 18px 40px -12px color-mix(in srgb,var(--accent) 70%,transparent);animation:pop .6s cubic-bezier(.2,.9,.3,1.4);"><img src="mira-logo-white.png" alt="Mira" style="width:60px;height:60px;animation:rayspin 28s linear infinite;" /></div>
          <div style="font-size:28px;font-weight:500;letter-spacing:-.035em;margin-top:26px;">Welcome to Mira</div>
          <div style="font-size:14.5px;line-height:1.5;color:var(--text-muted);margin-top:10px;max-width:280px;">Sign in to connect your Instagram and automate replies.</div>
          <button onClick="{{ signIn }}" style="margin-top:30px;display:flex;align-items:center;justify-content:center;gap:11px;height:52px;width:100%;max-width:320px;border-radius:999px;background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border:.5px solid var(--glass-border);box-shadow:var(--glass-shadow),var(--glass-highlight);color:var(--glass-text);font-family:inherit;font-size:15px;font-weight:500;cursor:pointer;box-shadow:var(--shadow-card);transition:transform .12s;" style-active="transform:scale(.98)">
            <sc-if value="{{ gIdle }}" hint-placeholder-val="{{ true }}"><svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/><path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"/></svg></sc-if>
            <sc-if value="{{ gBusy }}" hint-placeholder-val="{{ false }}"><div style="width:18px;height:18px;border:2px solid var(--border-strong);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;"></div></sc-if>
            {{ gLabel }}
          </button>
          <div style="position:absolute;bottom:40px;left:0;right:0;display:flex;align-items:center;justify-content:center;gap:8px;font-size:11.5px;color:var(--text-subtle);">By continuing you agree to our <span style="text-decoration:underline;">Terms</span> · <span style="text-decoration:underline;">Privacy</span></div>
        </div>
        </sc-if>

        <!-- INTRO -->
        <sc-if value="{{ stageIntro }}" hint-placeholder-val="{{ false }}">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;padding:58px 32px 40px;">
          <div style="display:flex;justify-content:flex-end;"><button onClick="{{ introSkip }}" style="border:none;background:none;color:var(--text-subtle);font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;padding:6px;">Skip</button></div>
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;">
            <div style="width:96px;height:96px;border-radius:28px;background:var(--accent-soft);color:var(--accent-deep);display:flex;align-items:center;justify-content:center;animation:pop .45s ease both;">{{ intro.ic }}</div>
            <div style="font-size:27px;font-weight:500;letter-spacing:-.03em;line-height:1.1;margin-top:30px;max-width:300px;">{{ intro.title }}</div>
            <div style="font-size:15px;line-height:1.55;color:var(--text-muted);margin-top:14px;max-width:300px;">{{ intro.body }}</div>
          </div>
          <div style="display:flex;align-items:center;justify-content:center;gap:7px;margin-bottom:24px;">
            <sc-for list="{{ introDots }}" as="d" hint-placeholder-count="3"><div style="width:{{ d.w }};height:7px;border-radius:4px;background:{{ d.bg }};transition:all .25s;"></div></sc-for>
          </div>
          <div style="display:flex;gap:10px;align-items:center;">
            <sc-if value="{{ introBackShow }}" hint-placeholder-val="{{ false }}"><button onClick="{{ introBack }}" style="width:52px;height:52px;border-radius:16px;border:1px solid var(--border);background:var(--bg-elev);color:var(--text-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg></button></sc-if>
            <button onClick="{{ introNext }}" style="flex:1;height:52px;border:none;border-radius:16px;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:16px;font-weight:500;cursor:pointer;box-shadow:0 10px 24px -10px color-mix(in srgb,var(--accent) 80%,transparent);transition:transform .12s;" style-active="transform:scale(.98)">{{ introCta }}</button>
          </div>
        </div>
        </sc-if>

        <!-- CONNECT INSTAGRAM -->
        <sc-if value="{{ stageConnect }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="position:absolute;inset:0;overflow-y:auto;display:flex;flex-direction:column;align-items:center;padding:54px 28px 30px;text-align:center;">
          <div style="width:64px;height:64px;border-radius:19px;background:linear-gradient(150deg,var(--accent),var(--accent-deep));display:flex;align-items:center;justify-content:center;box-shadow:0 14px 32px -12px color-mix(in srgb,var(--accent) 70%,transparent);"><img src="mira-logo-white.png" alt="Mira" style="width:44px;height:44px;" /></div>
          <div style="font-size:30px;font-weight:500;letter-spacing:-.04em;margin-top:18px;">Connect Instagram</div>
          <div style="font-size:14px;line-height:1.5;color:var(--text-muted);margin-top:9px;max-width:300px;">Mira manages your Instagram comments and DMs. Connect your account to begin.</div>
          <div style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:24px;box-shadow:var(--shadow-pop);padding:20px;margin-top:24px;text-align:left;">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
              <div style="width:44px;height:44px;border-radius:14px;background:var(--accent);color:var(--accent-fg);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="6"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg></div>
              <div><div style="font-size:14.5px;font-weight:500;">Instagram Business</div><div style="font-size:12px;color:var(--text-subtle);">Comments · DMs · Insights</div></div>
            </div>
            <div style="display:flex;flex-direction:column;gap:11px;margin-bottom:20px;">
              <sc-for list="{{ connectFeatures }}" as="f" hint-placeholder-count="3">
                <div style="display:flex;align-items:center;gap:11px;font-size:13px;color:var(--text-muted);"><span style="width:32px;height:32px;border-radius:10px;background:var(--accent-soft);color:var(--accent-deep);display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ f.ic }}</span>{{ f.text }}</div>
              </sc-for>
            </div>
            <button onClick="{{ connect }}" style="width:100%;height:52px;border:none;border-radius:16px;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:14.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px;box-shadow:var(--shadow-soft);transition:transform .12s;" style-active="transform:scale(.98)">
              <sc-if value="{{ connecting }}" hint-placeholder-val="{{ false }}"><div style="width:18px;height:18px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;"></div></sc-if>{{ connectLabel }}<sc-if value="{{ notConnecting }}" hint-placeholder-val="{{ true }}"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></sc-if>
            </button>
          </div>
          <div style="display:flex;align-items:center;justify-content:center;gap:6px;margin-top:16px;font-size:11.5px;color:var(--text-subtle);"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3Z"/></svg>Official Meta Graph API · your token stays on your device</div>
          <button onClick="{{ previewApp }}" style="margin-top:16px;border:none;background:none;color:var(--text-subtle);font-family:inherit;font-size:12.5px;cursor:pointer;text-decoration:underline;">Preview the app without connecting →</button>
        </div>
        </sc-if>

        <!-- TRAIN BRAIN -->
        <sc-if value="{{ stageBrain }}" hint-placeholder-val="{{ false }}">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;padding:60px 32px 40px;">
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;">
            <div style="width:96px;height:96px;border-radius:28px;background:var(--accent-soft);color:var(--accent-deep);display:flex;align-items:center;justify-content:center;position:relative;"><svg width="34" height="34" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.8 6.2L20 10l-6.2 1.8L12 18l-1.8-6.2L4 10l6.2-1.8L12 2Z"/></svg><div style="position:absolute;inset:-6px;border-radius:32px;border:2px solid var(--accent);opacity:.25;animation:glow 1.9s ease-in-out infinite;"></div></div>
            <div style="font-size:26px;font-weight:500;letter-spacing:-.03em;margin-top:28px;">Training your brain</div>
            <div style="font-size:14.5px;line-height:1.55;color:var(--text-muted);margin-top:12px;max-width:300px;">Mira is learning your voice from your recent replies &amp; captions, so every draft sounds like you.</div>
            <div style="width:100%;max-width:300px;height:6px;border-radius:4px;background:var(--bg-inset);margin-top:24px;overflow:hidden;"><div style="height:100%;width:78%;background:var(--accent);border-radius:4px;"></div></div>
            <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:20px;">
              <sc-for list="{{ brainChips }}" as="c" hint-placeholder-count="3"><div style="font-size:12.5px;color:var(--text-muted);background:var(--bg-elev);border:1px solid var(--border);border-radius:999px;padding:7px 13px;box-shadow:var(--shadow-card);">{{ c }}</div></sc-for>
            </div>
          </div>
          <button onClick="{{ brainDone }}" style="height:52px;border:none;border-radius:16px;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:16px;font-weight:500;cursor:pointer;box-shadow:0 10px 24px -10px color-mix(in srgb,var(--accent) 80%,transparent);transition:transform .12s;" style-active="transform:scale(.98)">Enter Mira</button>
          <button onClick="{{ brainDone }}" style="margin-top:10px;border:none;background:none;color:var(--text-subtle);font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;">Skip for now</button>
        </div>
        </sc-if>
      </div>
      </sc-if>

      <!-- ===== APP ===== -->
      <sc-if value="{{ booted }}" hint-placeholder-val="{{ false }}">
      <div style="position:absolute;inset:0;">

        <!-- ---- HOME ---- -->
        <sc-if value="{{ isHome }}" hint-placeholder-val="{{ true }}">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;">
          <div onPointerDown="{{ pullDown }}" onPointerMove="{{ pullMove }}" onPointerUp="{{ pullUp }}" class="scroll" style="flex:1;overflow-y:auto;overscroll-behavior:contain;padding:80px 18px 116px;">
            <div style="height:{{ pullH }};display:flex;align-items:flex-end;justify-content:center;overflow:hidden;transition:{{ pullTrans }};">
              <div style="display:flex;align-items:center;gap:7px;color:var(--text-subtle);font-size:12px;padding-bottom:8px;"><div style="width:15px;height:15px;border:2px solid var(--border-strong);border-top-color:var(--accent);border-radius:50%;{{ pullSpin }}"></div>{{ pullLabel }}</div>
            </div>
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;">
              <div>
                <div style="font-size:13px;color:var(--text-subtle);font-weight:500;">{{ greeting }}</div>
                <div style="font-size:32px;font-weight:500;letter-spacing:-.04em;line-height:1;margin-top:3px;">Home</div>
              </div>
              <button onClick="{{ openSettings }}" style="width:40px;height:40px;border-radius:50%;background:var(--glass-light-bg);backdrop-filter:blur(14px) saturate(130%);-webkit-backdrop-filter:blur(14px) saturate(130%);border:.5px solid rgba(255,255,255,.7);box-shadow:0 6px 18px rgba(60,50,95,.10),inset 0 1px 0 rgba(255,255,255,.7);color:var(--glass-text);font-weight:500;font-size:14px;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">DS</button>
            </div>
            <div style="border-radius:20px;background:var(--bg-elev);padding:20px 20px 18px;position:relative;overflow:hidden;animation:slideup .4s ease both;box-shadow:var(--shadow-card);">
              <div style="position:absolute;inset:0;background:radial-gradient(80% 95% at 96% 0%,color-mix(in srgb,var(--accent) 12%,transparent),transparent 62%);pointer-events:none;"></div>
              <div style="position:relative;">
                <div style="font-size:12.5px;color:var(--text-subtle);font-weight:500;">Here's how Mira is handling things</div>
                <div style="display:flex;align-items:flex-end;gap:11px;margin-top:6px;">
                  <div style="font-size:60px;font-weight:500;letter-spacing:-.05em;line-height:.82;color:var(--text);">{{ dash.coverage }}%</div>
                  <div style="padding-bottom:9px;font-size:13px;line-height:1.25;color:var(--text-muted);">of comments<br>covered</div>
                </div>
                <div style="display:flex;gap:22px;margin-top:16px;font-size:12.5px;color:var(--text-muted);">
                  <div><b style="color:var(--text);">{{ dash.replies }}</b> replies</div>
                  <div><b style="color:var(--text);">{{ dash.comments }}</b> comments</div>
                  <div><b style="color:var(--text);">{{ dash.facts }}</b> facts</div>
                </div>
              </div>
            </div>

            <button onClick="{{ goInbox }}" style="width:100%;margin-top:12px;text-align:left;border:none;border-radius:20px;cursor:pointer;font-family:inherit;background:linear-gradient(135deg,color-mix(in srgb,var(--accent) 13%,var(--bg-elev)),var(--bg-elev) 72%);box-shadow:var(--shadow-card);padding:16px;display:flex;align-items:center;gap:14px;transition:transform .12s;" style-active="transform:scale(.985)">
              <div style="width:46px;height:46px;border-radius:13px;background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4.5h14a2.2 2.2 0 0 1 2.2 2.2v7.4A2.2 2.2 0 0 1 19 16.3h-7.2L7.4 20v-3.7H5A2.2 2.2 0 0 1 2.8 14V6.7A2.2 2.2 0 0 1 5 4.5Z"/></svg></div>
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:8px;"><span style="font-size:17px;font-weight:500;color:var(--text);">Inbox</span><span style="font-size:11px;font-weight:500;color:#fff;background:var(--accent);border-radius:999px;padding:2px 8px;">{{ inboxCount }} new</span></div>
                <div style="font-size:12.5px;color:var(--text-muted);margin-top:2px;">drafts waiting for your approval</div>
              </div>
              <div style="display:flex;align-items:center;flex-shrink:0;">
                <sc-for list="{{ inboxPeek }}" as="p" hint-placeholder-count="3"><div style="width:30px;height:30px;border-radius:50%;background:{{ p.av }};color:#fff;font-weight:500;font-size:10.5px;display:flex;align-items:center;justify-content:center;margin-left:-8px;border:2px solid var(--bg-elev);">{{ p.initials }}</div></sc-for>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-subtle)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:9px;opacity:.5;"><path d="m9 6 6 6-6 6"/></svg>
              </div>
            </button>

        <div style="display:flex;flex-wrap:wrap;gap:11px;margin-top:11px;">
          <sc-for list="{{ homeTilesTop }}" as="t" hint-placeholder-count="2">
            <button onClick="{{ t.go }}" style="flex:1 1 calc(50% - 6px);min-width:0;text-align:left;border:none;border-radius:18px;cursor:pointer;font-family:inherit;background:var(--bg-elev);box-shadow:var(--shadow-card);padding:15px;display:flex;flex-direction:column;min-height:142px;transition:transform .12s;" style-active="transform:scale(.97)">
              <div style="width:38px;height:38px;border-radius:11px;background:{{ t.iconbg }};color:{{ t.iconfg }};display:flex;align-items:center;justify-content:center;">{{ t.icon }}</div><img src="{{ t.viz }}" style="width:100%;height:34px;object-fit:contain;object-position:left;display:block;margin-top:13px;" />
              <div style="margin-top:auto;padding-top:14px;">
                <div style="font-size:23px;font-weight:500;letter-spacing:-.03em;color:{{ t.metricCol }};line-height:1;">{{ t.metric }}</div>
                <div style="font-size:13.5px;font-weight:500;margin-top:6px;color:var(--text);">{{ t.label }}</div>
                <div style="font-size:12px;color:var(--text-subtle);margin-top:1px;">{{ t.sub }}</div>
              </div>
            </button>
          </sc-for>
        </div>

            <button onClick="{{ openStorefront }}" style="width:100%;margin-top:11px;text-align:left;border:none;border-radius:20px;overflow:hidden;cursor:pointer;font-family:inherit;background:var(--bg-elev);box-shadow:var(--shadow-card);display:block;padding:0;transition:transform .12s;" style-active="transform:scale(.99)">
              <div style="position:relative;background:linear-gradient(150deg,{{ sf.accent }},color-mix(in srgb,{{ sf.accent }} 60%,#000));padding:14px 16px 13px;display:flex;align-items:center;gap:11px;">
                <div style="width:38px;height:38px;border-radius:11px;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 11.2a2 2 0 0 1-2 1.8H8a2 2 0 0 1-2-1.8L5 8Z"/><path d="M9 8V6.2a3 3 0 0 1 6 0V8"/></svg></div>
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;align-items:center;gap:7px;"><span style="font-size:16.5px;font-weight:500;letter-spacing:-.01em;color:#fff;">Your storefront</span><span style="display:flex;align-items:center;gap:4px;font-size:9px;font-weight:500;letter-spacing:.06em;text-transform:none;color:#fff;background:rgba(255,255,255,.2);padding:3px 7px;border-radius:999px;"><span style="width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 2px rgba(90,95,224,.35);"></span>Live</span></div>
                  <div style="font-size:12.5px;color:rgba(255,255,255,.78);margin-top:1px;">mira.shop/{{ sf.handle }}</div>
                </div>
                <span style="font-size:13.5px;font-weight:500;color:#fff;display:flex;align-items:center;gap:1px;flex-shrink:0;">Open<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg></span>
              </div>
              <div style="height:16px;background:repeating-linear-gradient(90deg,{{ sf.accent }} 0 14px,color-mix(in srgb,{{ sf.accent }} 32%,#fff) 14px 28px);-webkit-mask:radial-gradient(8px at 50% 0,#0000 96%,#000) 50% 100%/28px 16px repeat-x;mask:radial-gradient(8px at 50% 0,#0000 96%,#000) 50% 100%/28px 16px repeat-x;"></div>
              <div class="scroll" style="display:flex;gap:10px;padding:13px 16px 14px;overflow-x:auto;background:var(--bg-inset);">
                <sc-for list="{{ storePreview }}" as="p" hint-placeholder-count="4">
                  <div style="width:94px;flex-shrink:0;">
                    <img src="{{ p.img }}" style="width:100%;height:94px;object-fit:cover;border-radius:13px;border:1px solid var(--border);display:block;" />
                    <div style="font-size:11.5px;font-weight:500;margin-top:7px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ p.title }}</div>
                    <div style="font-size:11.5px;color:var(--text-subtle);margin-top:1px;">{{ p.price }}</div>
                  </div>
                </sc-for>
              </div>
              <div style="border-top:1px solid var(--border);padding:11px 16px;font-size:12.5px;color:var(--text-muted);">{{ sf.productCount }} products · {{ sf.inStock }} in stock · auto-built from your catalog</div>
            </button>

        <div style="display:flex;flex-wrap:wrap;gap:11px;margin-top:11px;">
          <sc-for list="{{ homeTilesBottom }}" as="t" hint-placeholder-count="2">
            <button onClick="{{ t.go }}" style="flex:1 1 calc(50% - 6px);min-width:0;text-align:left;border:none;border-radius:18px;cursor:pointer;font-family:inherit;background:var(--bg-elev);box-shadow:var(--shadow-card);padding:15px;display:flex;flex-direction:column;min-height:142px;transition:transform .12s;" style-active="transform:scale(.97)">
              <div style="width:38px;height:38px;border-radius:11px;background:{{ t.iconbg }};color:{{ t.iconfg }};display:flex;align-items:center;justify-content:center;">{{ t.icon }}</div><img src="{{ t.viz }}" style="width:100%;height:34px;object-fit:contain;object-position:left;display:block;margin-top:13px;" />
              <div style="margin-top:auto;padding-top:14px;">
                <div style="font-size:23px;font-weight:500;letter-spacing:-.03em;color:{{ t.metricCol }};line-height:1;">{{ t.metric }}</div>
                <div style="font-size:13.5px;font-weight:500;margin-top:6px;color:var(--text);">{{ t.label }}</div>
                <div style="font-size:12px;color:var(--text-subtle);margin-top:1px;">{{ t.sub }}</div>
              </div>
            </button>
          </sc-for>
        </div>

            <div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:24px 6px 8px;">Reply mode</div>
            <div style="display:flex;gap:4px;background:var(--bg-inset);border-radius:11px;padding:3px;">
              <sc-for list="{{ modes }}" as="m" hint-placeholder-count="3">
                <button onClick="{{ m.set }}" style="flex:1;height:34px;border:none;border-radius:8px;font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;transition:all .18s;background:{{ m.bg }};color:{{ m.fg }};box-shadow:{{ m.sh }};">{{ m.label }}</button>
              </sc-for>
            </div>
            <div style="font-size:12.5px;color:var(--text-subtle);margin:9px 6px 0;line-height:1.4;">{{ modeDesc }}</div>

            <div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:22px 6px 8px;">Account safety</div>
            <div style="background:var(--bg-elev);border-radius:14px;padding:16px;box-shadow:var(--shadow-card);">
              <div style="display:flex;align-items:baseline;gap:7px;"><span style="font-size:22px;font-weight:500;color:var(--st-done);letter-spacing:-.02em;">{{ dash.sent }}</span><span style="font-size:13px;color:var(--text-subtle);">of {{ dash.cap }} daily send cap</span></div>
              <div style="height:6px;border-radius:4px;background:var(--bg-inset);margin-top:11px;overflow:hidden;"><div style="height:100%;width:{{ dash.capPct }};background:var(--st-done);border-radius:4px;transition:width .6s;"></div></div>
            </div>
            <div style="font-size:12.5px;color:var(--text-subtle);margin:8px 6px 0;line-height:1.45;">Every reply is uniqueness-checked &amp; paced — no bursts. Sends are jittered to stay human.</div>
          </div>
        </div>
        </sc-if>

        <!-- ---- INBOX ---- -->
        <sc-if value="{{ isInbox }}" hint-placeholder-val="{{ false }}">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;">
          <div style="padding:80px 18px 8px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div style="font-size:32px;font-weight:500;letter-spacing:-.04em;">Inbox</div>
              <div style="display:flex;align-items:center;gap:6px;font-size:11px;font-weight:500;color:var(--st-done);background:color-mix(in srgb,var(--st-done) 12%,transparent);padding:5px 10px;border-radius:999px;"><div style="width:6px;height:6px;border-radius:50%;background:var(--st-done);animation:glow 1.9s ease-in-out infinite;"></div>Live</div>
            </div>
            <div style="font-size:13px;color:var(--text-muted);margin-top:4px;">{{ inboxSub }}</div>
          </div>
          <div class="scroll" style="flex:1;overflow-y:auto;padding:6px 18px 116px;">
            <sc-if value="{{ hasDrafts }}" hint-placeholder-val="{{ true }}">
            <sc-for list="{{ drafts }}" as="d" hint-placeholder-count="3">
              <div style="position:relative;margin-bottom:11px;border-radius:18px;overflow:hidden;">
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:space-between;padding:0 24px;background:linear-gradient(90deg,var(--st-done),color-mix(in srgb,var(--st-done) 70%,#000) 100%);">
                  <div style="display:flex;align-items:center;gap:8px;color:#fff;font-weight:500;font-size:14px;opacity:{{ d.revR }};"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="m5 12 4 4L19 7"/></svg>Send</div>
                  <div style="display:flex;align-items:center;gap:8px;color:#fff;font-weight:500;font-size:14px;opacity:{{ d.revL }};">Skip<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg></div>
                </div>
                <div onClick="{{ d.open }}" onPointerDown="{{ d.down }}" onPointerMove="{{ d.move }}" onPointerUp="{{ d.up }}" style="position:relative;border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:18px;padding:14px;transform:{{ d.tf }};transition:{{ d.tr }};touch-action:pan-y;cursor:grab;">
                  <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:38px;height:38px;border-radius:50%;background:{{ d.av }};color:#fff;font-weight:500;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ d.initials }}</div>
                    <div style="flex:1;min-width:0;">
                      <div style="display:flex;align-items:center;gap:6px;"><span style="font-size:14px;font-weight:500;">{{ d.name }}</span><span style="font-size:11px;color:var(--text-subtle);">{{ d.time }}</span></div>
                      <div style="font-size:11.5px;color:var(--text-subtle);">{{ d.handle }}</div>
                    </div>
                    <div style="font-size:9.5px;font-weight:500;letter-spacing:.04em;text-transform:none;padding:4px 8px;border-radius:7px;background:{{ d.tagbg }};color:{{ d.tagfg }};flex-shrink:0;">{{ d.intent }}</div>
                  </div>
                  <div style="margin-top:11px;font-size:13px;line-height:1.4;color:var(--text-muted);background:var(--bg-inset);border-radius:11px;padding:9px 11px;">{{ d.comment }}</div>
                  <div style="margin-top:8px;display:flex;gap:8px;align-items:flex-start;">
                    <div style="width:20px;height:20px;border-radius:6px;background:var(--accent-soft);color:var(--accent-deep);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.6 5.4L19 9l-5.4 1.6L12 16l-1.6-5.4L5 9l5.4-1.6L12 2Z"/></svg></div>
                    <div style="flex:1;font-size:13px;line-height:1.45;color:var(--text);background:var(--accent-soft);border:1px solid color-mix(in srgb,var(--accent) 22%,transparent);border-radius:11px;border-top-left-radius:3px;padding:9px 11px;">{{ d.draft }}</div>
                  </div>
                  <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;">
                    <div style="font-size:10.5px;color:var(--text-subtle);display:flex;align-items:center;gap:5px;"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>{{ d.window }}</div>
                    <div style="display:flex;gap:7px;">
                      <button onClick="{{ d.skip }}" style="width:32px;height:32px;border-radius:9px;border:1px solid var(--border);background:var(--bg);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-subtle);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg></button>
                      <button onClick="{{ d.approve }}" style="height:32px;padding:0 14px;border-radius:9px;border:none;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:5px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="m5 12 4 4L19 7"/></svg>Send</button>
                    </div>
                  </div>
                </div>
              </div>
            </sc-for>
            </sc-if>
            <sc-if value="{{ noDrafts }}" hint-placeholder-val="{{ false }}">
              <div style="text-align:center;padding:70px 20px;">
                <div style="font-size:46px;">✨</div>
                <div style="font-size:18px;font-weight:500;margin-top:10px;letter-spacing:-.02em;">Inbox zero</div>
                <div style="font-size:13px;color:var(--text-muted);margin-top:6px;">Mira's handling everything. New drafts will appear here for your approval.</div>
                <button onClick="{{ resetDrafts }}" style="margin-top:18px;height:40px;padding:0 18px;border-radius:11px;border:1px solid var(--border);background:var(--bg-elev);color:var(--text);font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;">Replay demo drafts</button>
              </div>
            </sc-if>
          </div>
        </div>
        </sc-if>

        <!-- ---- OPPORTUNITIES (deal feed) ---- -->
        <sc-if value="{{ isOpps }}" hint-placeholder-val="{{ false }}">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;">
          <div style="padding:80px 18px 6px;">
            <div style="font-size:32px;font-weight:500;letter-spacing:-.04em;">Opportunities</div>
            <div style="display:flex;gap:11px;margin-top:14px;">
              <div style="flex:1;border:1px solid var(--border);border-radius:18px;background:var(--bg-elev);box-shadow:0 1px 2px rgba(24,24,27,.04),0 8px 22px rgba(60,50,95,.09);padding:14px 15px;">
                <div style="font-size:12px;font-weight:500;color:var(--text-subtle);">Open value</div>
                <div style="font-size:23px;font-weight:500;letter-spacing:-.03em;color:var(--text);margin-top:6px;">{{ oppSummary.pipeline }}</div>
              </div>
              <div style="flex:1;border:1px solid var(--border);border-radius:18px;background:var(--bg-elev);box-shadow:0 1px 2px rgba(24,24,27,.04),0 8px 22px rgba(60,50,95,.09);padding:14px 15px;">
                <div style="font-size:12px;font-weight:500;color:var(--text-subtle);">Won / mo</div>
                <div style="font-size:23px;font-weight:500;letter-spacing:-.03em;color:var(--text);margin-top:6px;">{{ oppSummary.won }}</div>
              </div>
              <div style="flex:1;border:1px solid var(--border);border-radius:18px;background:var(--bg-elev);box-shadow:0 1px 2px rgba(24,24,27,.04),0 8px 22px rgba(60,50,95,.09);padding:14px 15px;">
                <div style="font-size:12px;font-weight:500;color:var(--text-subtle);">Win rate</div>
                <div style="font-size:23px;font-weight:500;letter-spacing:-.03em;color:var(--text);margin-top:6px;">{{ oppSummary.rate }}</div>
              </div>
            </div>
          </div>
          <div style="padding:2px 18px 0;flex-shrink:0;">
            <div style="font-size:11.5px;font-weight:500;color:var(--text-subtle);display:flex;align-items:center;gap:7px;"><span style="width:6px;height:6px;border-radius:50%;background:var(--accent);animation:glow 2s ease-out infinite;"></span>Agents working for you</div>
          </div>
          <div class="scroll" style="display:flex;gap:11px;padding:11px 18px 4px;overflow-x:auto;flex-shrink:0;">
            <sc-for list="{{ agents }}" as="a" hint-placeholder-count="4">
              <div style="flex:0 0 auto;width:172px;border:1px solid var(--border);border-radius:18px;background:var(--bg-elev);box-shadow:0 1px 2px rgba(24,24,27,.04),0 8px 22px rgba(60,50,95,.09);padding:14px;">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                  <div style="width:36px;height:36px;border-radius:50%;background:{{ a.av }};color:#fff;display:flex;align-items:center;justify-content:center;font-size:12.5px;font-weight:500;letter-spacing:.02em;">{{ a.init }}</div>
                  <span style="width:7px;height:7px;border-radius:50%;background:var(--accent);animation:glow 2s ease-out infinite;flex-shrink:0;"></span>
                </div>
                <div style="font-size:14.5px;font-weight:500;color:var(--text);margin-top:11px;">{{ a.name }}</div>
                <div style="font-size:11.5px;color:var(--text-subtle);margin-top:2px;line-height:1.3;">{{ a.role }}</div>
                <div style="font-size:11.5px;font-weight:500;color:var(--text);margin-top:9px;">{{ a.stat }}</div>
              </div>
            </sc-for>
          </div>
          <div class="scroll" style="display:flex;gap:8px;padding:10px 18px 4px;overflow-x:auto;flex-shrink:0;">
            <sc-for list="{{ oppChips }}" as="ch" hint-placeholder-count="5">
              <button onClick="{{ ch.set }}" style="flex:0 0 auto;height:34px;padding:0 14px;border-radius:999px;border:1px solid {{ ch.bd }};background:{{ ch.bg }};color:{{ ch.fg }};font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:6px;">{{ ch.label }}<span style="font-size:11px;opacity:.7;">{{ ch.n }}</span></button>
            </sc-for>
          </div>
          <div class="scroll" style="flex:1;overflow-y:auto;padding:8px 18px 116px;">
            <sc-for list="{{ feed }}" as="o" hint-placeholder-count="4">
              <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:18px;padding:15px;margin-bottom:12px;animation:slideup .35s ease both;">
                <div style="display:flex;align-items:center;gap:11px;">
                  <div style="width:42px;height:42px;border-radius:50%;background:{{ o.av }};color:#fff;font-weight:500;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ o.initials }}</div>
                  <div style="flex:1;min-width:0;">
                    <div style="font-size:15px;font-weight:500;letter-spacing:-.01em;">{{ o.name }}</div>
                    <div style="font-size:12px;color:var(--text-subtle);">{{ o.handle }}</div>
                  </div>
                  <div style="position:relative;width:44px;height:44px;flex-shrink:0;">
                    <svg width="44" height="44" viewBox="0 0 44 44"><circle cx="22" cy="22" r="17" fill="none" stroke="var(--bg-inset)" stroke-width="4"/><circle cx="22" cy="22" r="17" fill="none" stroke="{{ o.confcol }}" stroke-width="4" stroke-linecap="round" stroke-dasharray="{{ o.ringC }}" stroke-dashoffset="{{ o.ringOff }}" transform="rotate(-90 22 22)"/></svg>
                    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:{{ o.confcol }};">{{ o.conf }}</div>
                  </div>
                </div>
                <div style="display:flex;align-items:center;gap:8px;margin-top:13px;">
                  <span style="font-size:9.5px;font-weight:500;letter-spacing:.04em;text-transform:none;padding:5px 9px;border-radius:7px;background:var(--bg-inset);color:var(--text-muted);">{{ o.type }}</span>
                  <span style="margin-left:auto;font-size:21px;font-weight:500;letter-spacing:-.03em;">{{ o.value }}</span>
                </div>
                <div style="position:relative;margin-top:16px;padding:0 2px;">
                  <div style="position:absolute;top:6px;left:8%;right:8%;height:2px;background:var(--border);"></div>
                  <div style="position:absolute;top:6px;left:8%;width:{{ o.fillW }};height:2px;background:var(--accent);transition:width .35s;"></div>
                  <div style="position:relative;display:flex;justify-content:space-between;">
                    <sc-for list="{{ o.stages }}" as="st" hint-placeholder-count="4">
                      <div onClick="{{ st.set }}" style="display:flex;flex-direction:column;align-items:center;gap:6px;flex:1;cursor:pointer;">
                        <div style="width:13px;height:13px;border-radius:50%;background:{{ st.dot }};border:2px solid {{ st.ring }};box-sizing:border-box;transition:all .2s;"></div>
                        <span style="font-size:9px;font-weight:500;color:{{ st.lcol }};white-space:nowrap;">{{ st.label }}</span>
                      </div>
                    </sc-for>
                  </div>
                </div>
                <sc-if value="{{ o.hasCta }}" hint-placeholder-val="{{ true }}">
                <button onClick="{{ o.cta }}" style="width:100%;margin-top:15px;height:38px;border-radius:11px;border:none;background:{{ o.ctaBg }};color:{{ o.ctaFg }};font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">{{ o.ctaLabel }}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="m9 6 6 6-6 6"/></svg></button>
                </sc-if>
                <sc-if value="{{ o.won }}" hint-placeholder-val="{{ false }}">
                <div style="width:100%;margin-top:15px;height:38px;border-radius:11px;background:color-mix(in srgb,var(--st-done) 14%,transparent);color:var(--st-done);font-size:13px;font-weight:500;display:flex;align-items:center;justify-content:center;gap:6px;">🎉 Closed won · {{ o.value }}</div>
                </sc-if>
              </div>
            </sc-for>
            <div style="text-align:center;font-size:11.5px;color:var(--text-subtle);padding:6px 0 0;">Mira detects deals from your DMs automatically.</div>
          </div>
        </div>
        </sc-if>

        <!-- ---- FLOWS (automations) ---- -->
        <sc-if value="{{ isAuto }}" hint-placeholder-val="{{ false }}">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;">
          <div style="padding:80px 18px 10px;display:flex;align-items:flex-start;justify-content:space-between;">
            <div>
              <div style="font-size:32px;font-weight:500;letter-spacing:-.04em;">Automations</div>
              <div style="font-size:13px;color:var(--text-muted);margin-top:4px;"><b style="color:var(--text);">{{ flowsActive }}</b> active · {{ flowsCount }} flows built</div>
            </div>
            
          </div>
          <div class="scroll" style="flex:1;overflow-y:auto;padding:6px 18px 116px;">
            <button onClick="{{ openTemplates }}" style="width:100%;border:1.5px dashed var(--border-strong);background:transparent;border-radius:20px;padding:24px 22px;display:flex;flex-direction:column;align-items:center;gap:14px;cursor:pointer;font-family:inherit;margin-bottom:14px;transition:transform .15s ease;" style-active="transform:scale(.985)"><div style="width:60px;height:60px;border-radius:18px;background:var(--text);color:var(--bg-elev);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></div><div style="text-align:center;"><div style="font-size:16px;font-weight:500;color:var(--text);">Create automation</div><div style="font-size:13px;color:var(--text-subtle);margin-top:3px;">Start from a template or build your own</div></div></button>
            <sc-for list="{{ flows }}" as="f" hint-placeholder-count="5">
              <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:14px;margin-bottom:11px;">
                <div onClick="{{ f.open }}" style="display:flex;gap:12px;align-items:flex-start;cursor:pointer;">
                  <div style="width:38px;height:38px;border-radius:11px;background:{{ f.iconbg }};color:{{ f.iconfg }};display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ f.icon }}</div>
                  <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:7px;"><span style="font-size:14.5px;font-weight:500;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ f.name }}</span><div style="width:6px;height:6px;border-radius:50%;background:{{ f.runDot }};flex-shrink:0;"></div></div>
                    <div style="font-size:11.5px;color:var(--text-subtle);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ f.runs }}</div>
                  </div>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-subtle)" stroke-width="2" stroke-linecap="round" style="margin-top:10px;flex-shrink:0;"><path d="m9 6 6 6-6 6"/></svg>
                </div>
                <div class="scroll" style="display:flex;align-items:center;gap:5px;margin-top:11px;overflow-x:auto;">
                  <sc-for list="{{ f.chips }}" as="cp" hint-placeholder-count="3">
                    <div style="display:flex;align-items:center;gap:5px;flex-shrink:0;">
                      <span style="font-size:10.5px;font-weight:500;padding:4px 9px;border-radius:7px;background:{{ cp.bg }};color:{{ cp.fg }};white-space:nowrap;">{{ cp.label }}</span>
                      <sc-if value="{{ cp.arrow }}" hint-placeholder-val="{{ true }}"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--text-subtle)" stroke-width="2.4" stroke-linecap="round"><path d="m9 6 6 6-6 6"/></svg></sc-if>
                    </div>
                  </sc-for>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;padding-top:11px;border-top:1px solid var(--border);">
                  <span style="font-size:11.5px;font-weight:500;color:{{ f.statusCol }};">{{ f.statusLabel }}</span>
                  <button onClick="{{ f.toggle }}" style="width:48px;height:29px;border-radius:999px;border:none;cursor:pointer;background:{{ f.trackbg }};position:relative;flex-shrink:0;transition:background .25s;padding:0;">
                    <div style="position:absolute;top:3px;left:3px;width:23px;height:23px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ f.knob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div>
                  </button>
                </div>
              </div>
            </sc-for>
            <button onClick="{{ newFlow }}" style="width:100%;border:1.5px dashed var(--border-strong);background:transparent;border-radius:16px;padding:16px;color:var(--text-muted);font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:2px;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>New automation</button>
          </div>
        </div>
        </sc-if>

        <!-- ===== TAB BAR (Option C: floating sliding-capsule) ===== -->
        <div style="position:absolute;left:16px;right:16px;bottom:30px;height:60px;z-index:30;background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border:.5px solid var(--glass-border);border-radius:23px;box-shadow:var(--glass-shadow),var(--glass-highlight);display:flex;align-items:center;gap:3px;padding:0 7px;box-sizing:border-box;">
          <sc-for list="{{ tabs }}" as="t" hint-placeholder-count="5">
            <button onClick="{{ t.go }}" style="flex:{{ t.btnFlex }};display:flex;align-items:center;justify-content:center;gap:7px;height:46px;min-width:46px;padding:{{ t.btnPad }};box-sizing:border-box;border:none;background:{{ t.btnBg }};color:{{ t.btnFg }};border-radius:15px;cursor:pointer;font-family:inherit;overflow:hidden;transition:flex-grow .32s cubic-bezier(.4,0,.2,1),background-color .3s cubic-bezier(.4,0,.2,1),color .25s ease,padding .3s cubic-bezier(.4,0,.2,1);" style-active="transform:scale(.95)">
              <span style="display:flex;flex-shrink:0;position:relative;">{{ t.icon }}<sc-if value="{{ t.badge }}" hint-placeholder-val="{{ false }}"><span style="position:absolute;top:-2px;right:-3px;width:8px;height:8px;border-radius:50%;background:var(--st-blocked);border:1.5px solid var(--glass-smoke-bg);"></span></sc-if></span>
              <span style="max-width:{{ t.lblMax }};opacity:{{ t.lblOp }};overflow:hidden;white-space:nowrap;font-size:13.5px;font-weight:500;letter-spacing:-.01em;transition:max-width .32s cubic-bezier(.4,0,.2,1),opacity .22s ease;">{{ t.label }}</span>
            </button>
          </sc-for>
        </div>
      </div>
      </sc-if>

      <!-- ===== ROUTE OVERLAY (push) ===== -->
      <sc-if value="{{ hasRoute }}" hint-placeholder-val="{{ false }}">
      <div style="position:absolute;inset:0;z-index:45;background:var(--bg);animation:{{ routeAnim }};display:flex;flex-direction:column;box-shadow:-8px 0 30px -10px rgba(0,0,0,.25);">
        <div style="padding:54px 12px 8px;display:flex;align-items:center;gap:4px;background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border-bottom:.5px solid var(--glass-border);">
          <button onClick="{{ pop }}" style="display:flex;align-items:center;gap:2px;border:none;background:none;color:var(--accent);font-family:inherit;font-size:16px;font-weight:500;cursor:pointer;padding:6px 6px;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>{{ routeBack }}</button>
          <div style="flex:1;text-align:center;font-size:16px;font-weight:500;letter-spacing:-.02em;margin-right:48px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ routeTitle }}</div>
        </div>

        <!-- CONTACTS -->
        <sc-if value="{{ rContacts }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="flex:1;overflow-y:auto;padding:14px 18px 30px;">
          <div style="display:flex;align-items:center;gap:8px;background:var(--bg-inset);border-radius:12px;padding:10px 12px;margin-bottom:14px;color:var(--text-subtle);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg><span style="font-size:13.5px;">Search contacts</span></div>
          <sc-for list="{{ contacts }}" as="c" hint-placeholder-count="6">
            <div onClick="{{ c.open }}" style="display:flex;align-items:center;gap:11px;padding:11px 6px;border-bottom:1px solid var(--border);cursor:pointer;">
              <div style="width:42px;height:42px;border-radius:50%;background:{{ c.av }};color:#fff;font-weight:500;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ c.initials }}</div>
              <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;gap:6px;"><span style="font-size:14.5px;font-weight:500;">{{ c.name }}</span><span style="font-size:9px;font-weight:500;letter-spacing:.04em;text-transform:none;padding:2px 6px;border-radius:5px;background:{{ c.stbg }};color:{{ c.stfg }};">{{ c.status }}</span></div>
                <div style="font-size:12px;color:var(--text-muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ c.last }}</div>
              </div>
              <div style="text-align:right;flex-shrink:0;"><div style="font-size:11px;color:var(--text-subtle);">{{ c.time }}</div><div style="font-size:12px;font-weight:500;color:var(--accent);margin-top:3px;">{{ c.score }}</div></div>
            </div>
          </sc-for>
        </div>
        </sc-if>

        <!-- CATALOG (management) -->
        <sc-if value="{{ rCatalog }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="flex:1;overflow-y:auto;padding:14px 18px 30px;">
          <button onClick="{{ openStorefront }}" style="width:100%;border:none;border-radius:13px;cursor:pointer;font-family:inherit;text-align:left;background:var(--accent-soft);padding:13px 14px;display:flex;align-items:center;gap:11px;margin-bottom:18px;" style-active="transform:scale(.99)">
            <div style="width:32px;height:32px;border-radius:9px;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9 5 4h14l2 5"/><path d="M4 9v10h16V9"/><path d="M9 13h6"/></svg></div>
            <div style="flex:1;min-width:0;"><div style="font-size:13.5px;font-weight:500;color:var(--accent-deep);">View live storefront</div><div style="font-size:11.5px;color:var(--accent-deep);opacity:.8;">mira.shop/{{ sf.handle }}</div></div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-deep)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
          </button>
          <div style="display:flex;align-items:center;justify-content:space-between;margin:0 4px 9px;">
            <span style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);">{{ catInStock }} in stock · {{ catFeatured }} featured</span>
            <button onClick="{{ addProduct }}" style="display:flex;align-items:center;gap:4px;border:none;background:none;color:var(--accent);font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>Add</button>
          </div>
          <div style="background:var(--bg-elev);border-radius:13px;overflow:hidden;box-shadow:0 1px 3px rgba(20,21,26,.05);">
            <sc-for list="{{ catalog }}" as="p" hint-placeholder-count="5">
              <sc-if value="{{ p.divider }}" hint-placeholder-val="{{ false }}"><div style="height:.5px;background:var(--border);margin-left:74px;"></div></sc-if>
              <div style="display:flex;align-items:center;gap:12px;padding:10px 13px;">
                <button onClick="{{ p.preview }}" style="width:48px;height:58px;border-radius:9px;border:none;cursor:pointer;flex-shrink:0;padding:0;overflow:hidden;"><img src="{{ p.img }}" style="width:48px;height:58px;object-fit:cover;display:block;" /></button>
                <div onClick="{{ p.preview }}" style="flex:1;min-width:0;cursor:pointer;">
                  <div style="display:flex;align-items:center;gap:6px;"><span style="font-size:14.5px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ p.title }}</span></div>
                  <div style="font-size:12px;color:var(--text-subtle);margin-top:1px;">{{ p.subtitle }}</div>
                  <div style="font-size:13px;margin-top:3px;"><b style="letter-spacing:-.01em;">{{ p.price }}</b> <span style="color:var(--text-subtle);">·</span> <span style="font-weight:500;color:{{ p.availCol }};">{{ p.availLabel }}</span></div>
                </div>
                <button onClick="{{ p.toggleFeatured }}" style="width:30px;height:30px;border-radius:8px;border:none;background:none;cursor:pointer;color:{{ p.starCol }};display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="19" height="19" viewBox="0 0 24 24" fill="{{ p.starFill }}" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><path d="m12 3 2.6 5.5 6 .8-4.4 4.2 1.1 6L12 16.8 6.7 19.5l1.1-6L3.4 9.3l6-.8z"/></svg></button>
                <button onClick="{{ p.toggleAvail }}" style="width:46px;height:28px;border-radius:999px;border:none;cursor:pointer;background:{{ p.trackbg }};position:relative;flex-shrink:0;transition:background .25s;padding:0;"><div style="position:absolute;top:3px;left:3px;width:22px;height:22px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ p.knob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div></button>
              </div>
            </sc-for>
          </div>
          <button onClick="{{ addProduct }}" style="width:100%;margin-top:12px;border:1.5px dashed var(--border-strong);background:transparent;border-radius:13px;padding:14px;color:var(--text-muted);font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>Add product</button>
          <div style="font-size:12px;color:var(--text-subtle);margin:12px 6px 0;line-height:1.45;">Toggle a product off and Mira instantly stops offering it in DMs and hides it from your storefront.</div>
        </div>
        </sc-if>

        <!-- STOREFRONT -->
        <sc-if value="{{ rStorefront }}" hint-placeholder-val="{{ false }}">
        <div style="flex:1;display:flex;flex-direction:column;min-height:0;">
          <div style="display:flex;align-items:center;gap:8px;padding:8px 16px;border-bottom:.5px solid var(--border);">
            <div style="flex:1;min-width:0;display:flex;align-items:center;gap:7px;background:var(--bg-inset);border-radius:9px;padding:7px 11px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-subtle)" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="3"/><path d="M3 9h18"/></svg><span style="font-size:12.5px;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ storefront.url }}</span></div>
            <button onClick="{{ copyUrl }}" style="width:34px;height:34px;border-radius:9px;border:1px solid var(--border);background:var(--bg-elev);color:var(--text-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="11" height="11" rx="2.5"/><path d="M5 15V5a2 2 0 0 1 2-2h8"/></svg></button>
            <button onClick="{{ storefront.customize }}" style="height:34px;padding:0 13px;border-radius:9px;border:none;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:5px;flex-shrink:0;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 5 4 4L8 20H4v-4z"/></svg>Edit</button>
          </div>
          <div class="scroll" style="flex:1;overflow-y:auto;">
            <sc-if value="{{ sfShowShop }}" hint-placeholder-val="{{ true }}">
              <div style="position:sticky;top:0;z-index:5;display:flex;align-items:center;gap:9px;padding:38px 18px 14px;background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border-bottom:.5px solid var(--glass-border);">
                <div style="width:8px;height:8px;border-radius:50%;background:{{ storefront.accent }};"></div>
                <span style="font-size:15px;font-weight:500;letter-spacing:-.02em;">{{ storefront.title }}</span>
                <span style="margin-left:auto;font-size:12.5px;color:var(--text-muted);">Shop</span>
              </div>
              <sc-if value="{{ storefront.minimal }}" hint-placeholder-val="{{ true }}">
                <div style="padding:40px 22px 30px;text-align:center;">
                  <div style="font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:none;color:{{ storefront.accent }};">Welcome</div>
                  <div style="font-size:32px;font-weight:500;letter-spacing:-.035em;line-height:1.02;margin-top:12px;">{{ storefront.heroHeadline }}</div>
                  <sc-if value="{{ storefront.hasTagline }}" hint-placeholder-val="{{ true }}"><div style="font-size:14.5px;color:var(--text-muted);line-height:1.5;margin-top:14px;">{{ storefront.heroTagline }}</div></sc-if>
                  <div style="display:inline-block;margin-top:22px;padding:12px 24px;border-radius:999px;background:{{ storefront.accent }};color:#fff;font-size:14px;font-weight:500;">View products</div>
                </div>
              </sc-if>
              <sc-if value="{{ storefront.split }}" hint-placeholder-val="{{ false }}">
                <div style="padding:26px 22px 24px;">
                  <div style="font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:none;color:{{ storefront.accent }};">Welcome</div>
                  <div style="font-size:30px;font-weight:500;letter-spacing:-.035em;line-height:1.04;margin-top:10px;">{{ storefront.heroHeadline }}</div>
                  <sc-if value="{{ storefront.hasTagline }}" hint-placeholder-val="{{ true }}"><div style="font-size:14px;color:var(--text-muted);line-height:1.5;margin-top:12px;">{{ storefront.heroTagline }}</div></sc-if>
                  <div style="margin-top:18px;height:170px;border-radius:16px;background:{{ storefront.accentSoft }};display:flex;align-items:center;justify-content:center;"><span style="font-size:64px;font-weight:500;color:{{ storefront.accent }};opacity:.55;letter-spacing:-.04em;">{{ storefront.heroMono }}</span></div>
                  <div style="display:inline-block;margin-top:18px;padding:12px 24px;border-radius:999px;background:{{ storefront.accent }};color:#fff;font-size:14px;font-weight:500;">View products</div>
                </div>
              </sc-if>
              <sc-if value="{{ storefront.showFeatured }}" hint-placeholder-val="{{ true }}">
                <div style="padding:14px 0 8px;">
                  <div style="padding:0 22px 12px;"><div style="font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:none;color:{{ storefront.accent }};">Featured</div><div style="font-size:21px;font-weight:500;letter-spacing:-.02em;margin-top:2px;">Picked for you</div></div>
                  <div class="scroll" style="display:flex;gap:14px;overflow-x:auto;padding:0 22px 6px;">
                    <sc-for list="{{ storefront.featured }}" as="p" hint-placeholder-count="3">
                      <div onClick="{{ p.open }}" style="flex:0 0 152px;cursor:pointer;">
                        <div style="aspect-ratio:4/5;border-radius:13px;overflow:hidden;"><img src="{{ p.img }}" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
                        <div style="display:flex;justify-content:space-between;gap:8px;margin-top:9px;"><span style="font-size:13.5px;font-weight:500;">{{ p.title }}</span><span style="font-size:13px;font-weight:500;">{{ p.price }}</span></div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:1px;">{{ p.subtitle }}</div>
                      </div>
                    </sc-for>
                  </div>
                </div>
              </sc-if>
              <div style="padding:20px 22px 10px;">
                <div style="font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:none;color:{{ storefront.accent }};">The shop</div>
                <div style="font-size:21px;font-weight:500;letter-spacing:-.02em;margin-top:2px;">All products</div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px 16px;padding:6px 22px 10px;">
                <sc-for list="{{ storefront.products }}" as="p" hint-placeholder-count="6">
                  <div onClick="{{ p.open }}" style="cursor:pointer;">
                    <div style="aspect-ratio:4/5;border-radius:13px;overflow:hidden;"><img src="{{ p.img }}" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
                    <div style="display:flex;justify-content:space-between;gap:8px;margin-top:9px;"><span style="font-size:13.5px;font-weight:500;line-height:1.2;">{{ p.title }}</span><span style="font-size:13px;font-weight:500;white-space:nowrap;">{{ p.price }}</span></div>
                    <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">{{ p.subtitle }}</div>
                  </div>
                </sc-for>
              </div>
              <sc-if value="{{ storefront.showAbout }}" hint-placeholder-val="{{ true }}">
                <div style="padding:26px 22px 10px;">
                  <div style="font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:none;color:{{ storefront.accent }};">About</div>
                  <div style="font-size:21px;font-weight:500;letter-spacing:-.02em;margin-top:2px;margin-bottom:10px;">{{ storefront.title }}</div>
                  <p style="font-size:14.5px;line-height:1.6;color:var(--text-muted);">{{ storefront.about }}</p>
                </div>
              </sc-if>
              <div style="border-top:.5px solid var(--border);margin-top:24px;padding:26px;text-align:center;font-size:11.5px;color:var(--text-subtle);">Powered by <b style="color:var(--text-muted);">Mira</b></div>
            </sc-if>

            <sc-if value="{{ sfShowProduct }}" hint-placeholder-val="{{ false }}">
              <div style="aspect-ratio:1;overflow:hidden;"><img src="{{ sfDetail.img }}" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
              <div style="padding:20px 22px 8px;">
                <sc-if value="{{ sfDetail.hasSub }}" hint-placeholder-val="{{ true }}"><div style="font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:none;color:{{ sfDetail.accent }};">{{ sfDetail.subtitle }}</div></sc-if>
                <div style="font-size:27px;font-weight:500;letter-spacing:-.025em;line-height:1.1;margin-top:6px;">{{ sfDetail.title }}</div>
                <div style="font-size:21px;font-weight:500;margin-top:11px;">{{ sfDetail.price }}</div>
                <p style="font-size:14.5px;line-height:1.6;color:var(--text-muted);margin-top:16px;">{{ sfDetail.desc }}</p>
                <sc-if value="{{ sfDetail.cta }}" hint-placeholder-val="{{ true }}">
                  <div style="margin-top:22px;height:50px;border-radius:13px;background:{{ sfDetail.accent }};color:#fff;font-size:15.5px;font-weight:500;display:flex;align-items:center;justify-content:center;">{{ sfDetail.buyLabel }}</div>
                  <div style="text-align:center;margin-top:8px;font-size:11.5px;color:var(--text-subtle);">Opens {{ sfDetail.host }}</div>
                </sc-if>
                <sc-if value="{{ sfDetail.noCta }}" hint-placeholder-val="{{ false }}">
                  <div style="margin-top:22px;padding:15px;border-radius:13px;background:var(--bg-inset);font-size:13.5px;color:var(--text-muted);text-align:center;">💬 Ask in DMs to order — Mira will handle it</div>
                </sc-if>
              </div>
              <div style="padding:26px 22px 10px;">
                <div style="font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:none;color:{{ sfDetail.accent }};">More from</div>
                <div style="font-size:21px;font-weight:500;letter-spacing:-.02em;margin-top:2px;">{{ storefront.title }}</div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px 16px;padding:6px 22px 10px;">
                <sc-for list="{{ sfDetail.more }}" as="p" hint-placeholder-count="4">
                  <div onClick="{{ p.open }}" style="cursor:pointer;">
                    <div style="aspect-ratio:4/5;border-radius:13px;overflow:hidden;"><img src="{{ p.img }}" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
                    <div style="display:flex;justify-content:space-between;gap:8px;margin-top:9px;"><span style="font-size:13.5px;font-weight:500;">{{ p.title }}</span><span style="font-size:13px;font-weight:500;">{{ p.price }}</span></div>
                  </div>
                </sc-for>
              </div>
              <div style="border-top:.5px solid var(--border);margin-top:24px;padding:26px;text-align:center;font-size:11.5px;color:var(--text-subtle);">Powered by <b style="color:var(--text-muted);">Mira</b></div>
            </sc-if>
          </div>
        </div>
        </sc-if>

        <!-- ANALYTICS -->
        <sc-if value="{{ rAnalytics }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="flex:1;overflow-y:auto;padding:16px 18px 30px;">
          <div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:2px 6px 8px;">Account growth</div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px;">
            <sc-for list="{{ growth }}" as="g" hint-placeholder-count="3">
              <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:15px;padding:12px;">
                <div style="font-size:9.5px;font-weight:500;letter-spacing:.05em;text-transform:none;color:var(--text-subtle);">{{ g.label }}</div>
                <div style="font-size:20px;font-weight:500;letter-spacing:-.03em;margin-top:5px;">{{ g.value }}</div>
                <div style="font-size:10px;font-weight:500;color:{{ g.dcol }};margin-top:3px;">{{ g.delta }}</div>
              </div>
            </sc-for>
          </div>
          <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:16px;margin-top:13px;margin-bottom:3px;">
            <div style="font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);margin-bottom:11px;">Comments handled vs needs you</div>
            <div style="display:flex;height:14px;border-radius:7px;overflow:hidden;background:var(--bg-inset);">
              <div style="width:{{ coverageSplit.handledPct }};background:var(--st-done);"></div>
              <div style="width:{{ coverageSplit.needsPct }};background:var(--st-warm);"></div>
            </div>
            <div style="display:flex;justify-content:space-between;margin-top:10px;font-size:12px;">
              <span style="color:var(--text-muted);"><b style="color:var(--st-done);">{{ coverageSplit.handled }}</b> handled by Mira</span>
              <span style="color:var(--text-muted);"><b style="color:var(--st-warm);">{{ coverageSplit.needs }}</b> need you</span>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:11px;">
            <sc-for list="{{ stats }}" as="s" hint-placeholder-count="4">
              <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:15px;padding:14px;">
                <div style="font-size:10px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);">{{ s.label }}</div>
                <div style="font-size:26px;font-weight:500;letter-spacing:-.03em;margin-top:5px;">{{ s.value }}</div>
                <div style="font-size:11px;font-weight:500;color:{{ s.dcol }};margin-top:3px;">{{ s.delta }}</div>
              </div>
            </sc-for>
          </div>
          <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:16px;margin-top:13px;">
            <div style="font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);">Replies — last 14 days</div>
            <div style="display:flex;align-items:flex-end;gap:4px;height:96px;margin-top:14px;">
              <sc-for list="{{ chart }}" as="b" hint-placeholder-count="14">
                <div style="flex:1;display:flex;flex-direction:column;justify-content:flex-end;align-items:center;height:100%;gap:3px;"><div style="width:100%;border-radius:3px 3px 0 0;background:var(--accent);height:{{ b.h }};min-height:3px;opacity:{{ b.op }};"></div></div>
              </sc-for>
            </div>
          </div>
          <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:16px;margin-top:13px;">
            <div style="font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);margin-bottom:11px;">Reply intents</div>
            <sc-for list="{{ intents }}" as="i" hint-placeholder-count="5">
              <div style="display:flex;align-items:center;gap:9px;margin-bottom:9px;">
                <span style="width:78px;font-size:12px;color:var(--text-muted);flex-shrink:0;">{{ i.label }}</span>
                <div style="flex:1;height:8px;border-radius:5px;background:var(--bg-inset);overflow:hidden;"><div style="height:100%;width:{{ i.w }};background:{{ i.col }};border-radius:5px;"></div></div>
                <span style="font-size:11.5px;font-weight:500;width:24px;text-align:right;">{{ i.n }}</span>
              </div>
            </sc-for>
          </div>
        </div>
        </sc-if>


        <!-- GUARD CENTER -->
        <sc-if value="{{ rGuard }}" hint-placeholder-val="{{ false }}">
        <div style="flex:1;display:flex;flex-direction:column;min-height:0;">
          <div style="padding:12px 18px 10px;flex-shrink:0;">
            <div style="display:flex;gap:4px;background:var(--bg-inset);border-radius:11px;padding:3px;">
              <sc-for list="{{ guardSegs }}" as="g" hint-placeholder-count="3">
                <button onClick="{{ g.set }}" style="flex:1;height:34px;border:none;border-radius:8px;font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;transition:all .18s;background:{{ g.bg }};color:{{ g.fg }};box-shadow:{{ g.sh }};">{{ g.label }}</button>
              </sc-for>
            </div>
          </div>
          <div class="scroll" style="flex:1;overflow-y:auto;padding:6px 18px 30px;">
            <sc-if value="{{ gSegFlagged }}" hint-placeholder-val="{{ true }}">
              <sc-for list="{{ flaggedCards }}" as="f" hint-placeholder-count="3">
                <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:18px;padding:14px;margin-bottom:11px;opacity:{{ f.opacity }};transition:opacity .28s;">
                  <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:38px;height:38px;border-radius:50%;background:{{ f.av }};color:#fff;font-weight:500;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ f.initials }}</div>
                    <div style="flex:1;min-width:0;"><div style="display:flex;align-items:center;gap:6px;"><span style="font-size:14px;font-weight:500;">{{ f.name }}</span><span style="font-size:11px;color:var(--text-subtle);">{{ f.ts }}</span></div><div style="font-size:11.5px;color:var(--text-subtle);">{{ f.handle }} · {{ f.kindLabel }}</div></div>
                    <div style="font-size:9.5px;font-weight:500;letter-spacing:.04em;text-transform:none;padding:4px 8px;border-radius:7px;background:{{ f.tagbg }};color:{{ f.tagfg }};flex-shrink:0;">{{ f.catLabel }}</div>
                  </div>
                  <div style="margin-top:11px;font-size:13px;line-height:1.4;color:var(--text-muted);background:var(--bg-inset);border-radius:11px;padding:9px 11px;">{{ f.text }}</div>
                  <div style="display:flex;gap:6px;margin-top:9px;">
                    <span style="font-size:10px;color:var(--text-subtle);background:var(--bg-inset);border-radius:6px;padding:3px 8px;">tone · {{ f.tone }}</span>
                    <span style="font-size:10px;color:var(--text-subtle);background:var(--bg-inset);border-radius:6px;padding:3px 8px;">signal · {{ f.signal }}</span>
                    <span style="font-size:10px;color:var(--text-subtle);background:var(--bg-inset);border-radius:6px;padding:3px 8px;">{{ f.sevLabel }}</span>
                  </div>
                  <div style="display:flex;gap:7px;margin-top:12px;">
                    <button onClick="{{ f.allow }}" style="flex:1;height:34px;border-radius:9px;border:1px solid var(--border);background:var(--bg);color:var(--text-muted);font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;">Allow</button>
                    <button onClick="{{ f.hide }}" style="flex:1;height:34px;border-radius:9px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;">Hide</button>
                    <button onClick="{{ f.block }}" style="flex:1;height:34px;border-radius:9px;border:none;background:var(--st-blocked);color:#fff;font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;">Block</button>
                  </div>
                </div>
              </sc-for>
            </sc-if>
            <sc-if value="{{ gSegRules }}" hint-placeholder-val="{{ false }}">
              <div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:6px 6px 8px;">Auto-flag categories</div>
              <div style="border:1px solid var(--border);border-radius:15px;background:var(--bg-elev);overflow:hidden;">
                <sc-for list="{{ guardRuleRows }}" as="r" hint-placeholder-count="4">
                  <div style="display:flex;align-items:center;gap:12px;padding:13px 14px;border-bottom:1px solid var(--border);">
                    <div style="flex:1;"><div style="font-size:13.5px;font-weight:500;">{{ r.label }}</div><div style="font-size:11.5px;color:var(--text-subtle);">{{ r.sub }}</div></div>
                    <button onClick="{{ r.toggle }}" style="width:48px;height:29px;border-radius:999px;border:none;cursor:pointer;background:{{ r.trackbg }};position:relative;flex-shrink:0;transition:background .25s;padding:0;"><div style="position:absolute;top:3px;left:3px;width:23px;height:23px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ r.knob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div></button>
                  </div>
                </sc-for>
              </div>
              <div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:22px 6px 8px;">Keyword blocklist</div>
              <div style="border:1px solid var(--border);border-radius:15px;background:var(--bg-elev);padding:14px;">
                <div style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:11px;">
                  <sc-for list="{{ blockChips }}" as="cp" hint-placeholder-count="3">
                    <div style="display:flex;align-items:center;gap:6px;height:32px;padding:0 6px 0 12px;border-radius:9px;background:var(--accent-soft);color:var(--accent-deep);font-size:13px;font-weight:500;">{{ cp.label }}<button onClick="{{ cp.remove }}" style="width:18px;height:18px;border-radius:50%;border:none;background:color-mix(in srgb,var(--accent) 22%,transparent);color:var(--accent-deep);cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg></button></div>
                  </sc-for>
                </div>
                <div style="display:flex;gap:8px;"><input value="{{ kwDraft }}" onInput="{{ setKwDraft }}" onKeyDown="{{ addBlockKwKey }}" placeholder="Block a word + Enter" style="flex:1;border:1px solid var(--border);background:var(--bg);border-radius:11px;padding:10px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;" /><button onClick="{{ addBlockKw }}" style="width:44px;border-radius:11px;border:1px solid var(--border);background:var(--bg-inset);color:var(--accent);cursor:pointer;display:flex;align-items:center;justify-content:center;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button></div>
              </div>
            </sc-if>
            <sc-if value="{{ gSegBlock }}" hint-placeholder-val="{{ false }}">
              <sc-for list="{{ blockedUsers }}" as="b" hint-placeholder-count="2">
                <div style="display:flex;align-items:center;gap:11px;padding:11px 6px;border-bottom:1px solid var(--border);">
                  <div style="width:42px;height:42px;border-radius:50%;background:var(--bg-inset);color:var(--text-subtle);font-weight:500;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ b.initials }}</div>
                  <div style="flex:1;min-width:0;"><div style="font-size:14.5px;font-weight:500;">{{ b.username }}</div><div style="font-size:12px;color:var(--text-muted);margin-top:2px;">{{ b.reason }} · {{ b.ts }}</div></div>
                  <button onClick="{{ b.unblock }}" style="height:32px;padding:0 14px;border-radius:9px;border:1px solid var(--border);background:var(--bg-elev);color:var(--accent);font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;flex-shrink:0;">Unblock</button>
                </div>
              </sc-for>
            </sc-if>
          </div>
        </div>
        </sc-if>

        <!-- TEMPLATES -->
        <sc-if value="{{ rTemplates }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="flex:1;overflow-y:auto;padding:14px 18px 30px;">
          <div style="font-size:13px;color:var(--text-muted);margin:0 4px 12px;line-height:1.45;">Start from a prebuilt flow — tap Use template to drop it into the builder.</div>
          <button onClick="{{ newFlow }}" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:14px;display:flex;align-items:center;gap:12px;cursor:pointer;font-family:inherit;text-align:left;margin-bottom:11px;transition:transform .15s ease;" style-active="transform:scale(.985)"><div style="width:38px;height:38px;border-radius:11px;background:var(--text);color:var(--bg-elev);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></div><div style="flex:1;min-width:0;"><div style="font-size:14.5px;font-weight:500;color:var(--text);">Create blank</div><div style="font-size:12px;color:var(--text-subtle);margin-top:1px;">Start with an empty canvas</div></div><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-subtle)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="m9 18 6-6-6-6"/></svg></button>
          <sc-for list="{{ templates }}" as="t" hint-placeholder-count="5">
            <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:14px;margin-bottom:11px;">
              <div style="display:flex;gap:12px;align-items:flex-start;">
                <div style="width:38px;height:38px;border-radius:11px;background:var(--accent-soft);color:var(--accent-deep);display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ t.icon }}</div>
                <div style="flex:1;min-width:0;"><div style="font-size:14.5px;font-weight:500;">{{ t.name }}</div><div style="font-size:12px;color:var(--text-muted);margin-top:2px;line-height:1.4;">{{ t.desc }}</div></div>
              </div>
              <div class="scroll" style="display:flex;align-items:center;gap:5px;margin-top:11px;overflow-x:auto;">
                <sc-for list="{{ t.chips }}" as="cp" hint-placeholder-count="3">
                  <div style="display:flex;align-items:center;gap:5px;flex-shrink:0;">
                    <span style="font-size:10.5px;font-weight:500;padding:4px 9px;border-radius:7px;background:{{ cp.bg }};color:{{ cp.fg }};white-space:nowrap;">{{ cp.label }}</span>
                    <sc-if value="{{ cp.arrow }}" hint-placeholder-val="{{ true }}"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--text-subtle)" stroke-width="2.4" stroke-linecap="round"><path d="m9 6 6 6-6 6"/></svg></sc-if>
                  </div>
                </sc-for>
              </div>
              <button onClick="{{ t.use }}" style="width:100%;margin-top:13px;height:38px;border-radius:11px;border:none;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">Use template<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="m9 6 6 6-6 6"/></svg></button>
            </div>
          </sc-for>
        </div>
        </sc-if>

        <!-- ORDERS -->
        <sc-if value="{{ rOrders }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="flex:1;overflow-y:auto;padding:14px 18px 30px;">
          <div style="display:flex;gap:10px;margin-bottom:14px;">
            <div style="flex:1;border-radius:15px;border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);padding:11px 12px;"><div style="font-size:9.5px;font-weight:500;letter-spacing:.05em;text-transform:none;color:var(--text-subtle);">New</div><div style="font-size:21px;font-weight:500;letter-spacing:-.03em;color:var(--accent);margin-top:2px;">{{ orderSummary.open }}</div></div>
            <div style="flex:1;border-radius:15px;border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);padding:11px 12px;"><div style="font-size:9.5px;font-weight:500;letter-spacing:.05em;text-transform:none;color:var(--text-subtle);">Orders</div><div style="font-size:21px;font-weight:500;letter-spacing:-.03em;margin-top:2px;">{{ orderSummary.total }}</div></div>
            <div style="flex:1;border-radius:15px;border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);padding:11px 12px;"><div style="font-size:9.5px;font-weight:500;letter-spacing:.05em;text-transform:none;color:var(--text-subtle);">Revenue</div><div style="font-size:21px;font-weight:500;letter-spacing:-.03em;color:var(--st-done);margin-top:2px;">{{ orderSummary.revenue }}</div></div>
          </div>
          <sc-for list="{{ orders }}" as="o" hint-placeholder-count="5">
            <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:14px;margin-bottom:11px;">
              <div style="display:flex;align-items:center;gap:11px;">
                <div style="width:40px;height:40px;border-radius:50%;background:{{ o.av }};color:#fff;font-weight:500;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ o.initials }}</div>
                <div style="flex:1;min-width:0;"><div style="font-size:14.5px;font-weight:500;">{{ o.customer }}</div><div style="font-size:12px;color:var(--text-subtle);">{{ o.product }}</div></div>
                <div style="text-align:right;flex-shrink:0;"><div style="font-size:15px;font-weight:500;letter-spacing:-.02em;">{{ o.amount }}</div><div style="font-size:10.5px;color:var(--text-subtle);margin-top:1px;">{{ o.ts }}</div></div>
              </div>
              <div style="display:flex;align-items:center;gap:8px;margin-top:12px;">
                <span style="font-size:9.5px;font-weight:500;letter-spacing:.04em;text-transform:none;padding:5px 9px;border-radius:7px;background:{{ o.stbg }};color:{{ o.stfg }};">{{ o.statusLabel }}</span>
                <sc-if value="{{ o.hasCta }}" hint-placeholder-val="{{ true }}"><button onClick="{{ o.advance }}" style="margin-left:auto;height:32px;padding:0 14px;border-radius:9px;border:none;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;">{{ o.ctaLabel }}</button></sc-if>
                <sc-if value="{{ o.done }}" hint-placeholder-val="{{ false }}"><span style="margin-left:auto;font-size:12px;font-weight:500;color:var(--st-done);">✓ Shipped</span></sc-if>
              </div>
            </div>
          </sc-for>
        </div>
        </sc-if>

        <!-- STORE INSIGHTS -->
        <sc-if value="{{ rStoreStats }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="flex:1;overflow-y:auto;padding:16px 18px 30px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:11px;">
            <sc-for list="{{ storeStatCards }}" as="c" hint-placeholder-count="4">
              <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:15px;padding:14px;">
                <div style="font-size:10px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);">{{ c.label }}</div>
                <div style="font-size:26px;font-weight:500;letter-spacing:-.03em;margin-top:5px;">{{ c.value }}</div>
                <div style="font-size:11px;font-weight:500;color:{{ c.dcol }};margin-top:3px;">{{ c.delta }}</div>
              </div>
            </sc-for>
          </div>
          <div style="border:1px solid var(--border);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:16px;padding:16px;margin-top:13px;">
            <div style="font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);margin-bottom:13px;">Top products</div>
            <sc-for list="{{ topProducts }}" as="i" hint-placeholder-count="4">
              <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px;">
                <span style="width:120px;font-size:12px;color:var(--text-muted);flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ i.label }}</span>
                <div style="flex:1;height:8px;border-radius:5px;background:var(--bg-inset);overflow:hidden;"><div style="height:100%;width:{{ i.w }};background:{{ i.col }};border-radius:5px;"></div></div>
                <span style="font-size:11.5px;font-weight:500;width:24px;text-align:right;">{{ i.n }}</span>
              </div>
            </sc-for>
          </div>
        </div>
        </sc-if>

        <!-- ADD PRODUCT -->
        <sc-if value="{{ rAddProduct }}" hint-placeholder-val="{{ false }}">
        <div class="scroll" style="flex:1;overflow-y:auto;padding:18px 18px 30px;">
          <div style="display:flex;align-items:center;gap:13px;margin-bottom:18px;">
            <div style="width:60px;height:60px;border-radius:16px;background:linear-gradient(150deg,var(--accent-soft),color-mix(in srgb,var(--accent) 6%,var(--bg-inset)));color:var(--accent-deep);display:flex;align-items:center;justify-content:center;font-weight:500;font-size:20px;flex-shrink:0;">{{ newProduct.mono }}</div>
            <div style="font-size:13px;color:var(--text-muted);line-height:1.45;">Add a product to your catalog. It appears in your storefront and Mira can recommend it in DMs.</div>
          </div>
          <div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:0 4px 7px;">Name</div>
          <input value="{{ newProduct.name }}" onInput="{{ newProduct.setName }}" placeholder="Vitamin C Glow Serum" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:12px;padding:12px 14px;font-family:inherit;font-size:15px;color:var(--text);outline:none;" />
          <div style="display:flex;gap:11px;margin-top:14px;">
            <div style="flex:1;"><div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:0 4px 7px;">Price</div><input value="{{ newProduct.price }}" onInput="{{ newProduct.setPrice }}" placeholder="₹1,299" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:12px;padding:12px 14px;font-family:inherit;font-size:15px;color:var(--text);outline:none;" /></div>
            <div style="flex:1;"><div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:0 4px 7px;">Subtitle</div><input value="{{ newProduct.subtitle }}" onInput="{{ newProduct.setSubtitle }}" placeholder="Brightening · 15%" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:12px;padding:12px 14px;font-family:inherit;font-size:15px;color:var(--text);outline:none;" /></div>
          </div>
          <div style="font-size:11.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin:14px 4px 7px;">Description</div>
          <textarea rows="4" value="{{ newProduct.desc }}" onInput="{{ newProduct.setDesc }}" placeholder="A lightweight serum that…" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:12px;padding:12px 14px;font-family:inherit;font-size:15px;color:var(--text);outline:none;resize:none;line-height:1.45;"></textarea>
          <div style="display:flex;align-items:center;gap:12px;margin-top:16px;border:1px solid var(--border);background:var(--bg-elev);border-radius:14px;padding:14px;">
            <div style="flex:1;"><div style="font-size:14px;font-weight:500;">In stock</div><div style="font-size:12px;color:var(--text-subtle);">Show as available in the shop</div></div>
            <button onClick="{{ newProduct.toggleAvail }}" style="width:48px;height:29px;border-radius:999px;border:none;cursor:pointer;background:{{ newProduct.avTrack }};position:relative;flex-shrink:0;transition:background .25s;padding:0;"><div style="position:absolute;top:3px;left:3px;width:23px;height:23px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ newProduct.avKnob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div></button>
          </div>
          <button onClick="{{ newProduct.save }}" style="width:100%;margin-top:20px;height:52px;border:none;border-radius:15px;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:16px;font-weight:500;cursor:pointer;box-shadow:0 10px 24px -10px color-mix(in srgb,var(--accent) 80%,transparent);">Add product</button>
        </div>
        </sc-if>

        <!-- THREAD -->
        <sc-if value="{{ rThread }}" hint-placeholder-val="{{ false }}">
        <div style="flex:1;display:flex;flex-direction:column;min-height:0;">
          <div class="scroll" style="flex:1;overflow-y:auto;padding:16px 16px 12px;display:flex;flex-direction:column;gap:3px;">
            <div style="text-align:center;font-size:11px;color:var(--text-subtle);margin-bottom:10px;">{{ thread.meta }}</div>
            <sc-for list="{{ thread.msgs }}" as="m" hint-placeholder-count="4">
              <div style="display:flex;justify-content:{{ m.justify }};margin-top:{{ m.gap }};">
                <div style="max-width:75%;display:flex;flex-direction:column;align-items:{{ m.align }};">
                  <sc-if value="{{ m.aiTag }}" hint-placeholder-val="{{ false }}"><div style="font-size:9.5px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--accent-deep);margin-bottom:3px;display:flex;align-items:center;gap:3px;">✦ Mira drafted</div></sc-if>
                  <div style="padding:9px 13px;border-radius:19px;font-size:14px;line-height:1.35;background:{{ m.bg }};color:{{ m.fg }};{{ m.corner }}animation:msgin .3s ease both;">{{ m.text }}</div>
                </div>
              </div>
            </sc-for>
            <sc-if value="{{ thread.typing }}" hint-placeholder-val="{{ false }}">
              <div style="display:flex;justify-content:flex-start;margin-top:6px;"><div style="padding:11px 15px;border-radius:19px;background:var(--bubble-them);display:flex;gap:4px;"><div style="width:7px;height:7px;border-radius:50%;background:var(--text-subtle);animation:dotp 1.2s infinite;"></div><div style="width:7px;height:7px;border-radius:50%;background:var(--text-subtle);animation:dotp 1.2s infinite .15s;"></div><div style="width:7px;height:7px;border-radius:50%;background:var(--text-subtle);animation:dotp 1.2s infinite .3s;"></div></div></div>
            </sc-if>
          </div>
          <sc-if value="{{ thread.suggest }}" hint-placeholder-val="{{ false }}">
            <div style="padding:0 14px 8px;"><button onClick="{{ sendSuggest }}" style="width:100%;border:1px solid color-mix(in srgb,var(--accent) 30%,transparent);background:var(--accent-soft);border-radius:14px;padding:11px 13px;display:flex;align-items:center;gap:9px;cursor:pointer;font-family:inherit;text-align:left;">
              <div style="width:22px;height:22px;border-radius:6px;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.6 5.4L19 9l-5.4 1.6L12 16l-1.6-5.4L5 9l5.4-1.6L12 2Z"/></svg></div>
              <div style="flex:1;min-width:0;"><div style="font-size:10px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--accent-deep);">Mira suggests</div><div style="font-size:13px;color:var(--text);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ thread.suggestText }}</div></div>
              <div style="font-size:12.5px;font-weight:500;color:var(--accent);flex-shrink:0;">Send →</div>
            </button></div>
          </sc-if>
          <div style="padding:10px 14px 30px;border-top:1px solid var(--border);display:flex;align-items:center;gap:9px;background:var(--bg);">
            <div style="flex:1;display:flex;align-items:center;background:var(--bg-inset);border:1px solid var(--border);border-radius:999px;padding:4px 5px 4px 15px;">
              <input value="{{ composer }}" onInput="{{ onCompose }}" placeholder="Message…" style="flex:1;border:none;background:none;outline:none;font-family:inherit;font-size:14px;color:var(--text);min-width:0;" />
              <button onClick="{{ sendMsg }}" style="width:32px;height:32px;border-radius:50%;background:var(--glass-light-bg);backdrop-filter:blur(14px) saturate(130%);-webkit-backdrop-filter:blur(14px) saturate(130%);border:.5px solid rgba(255,255,255,.7);box-shadow:0 6px 18px rgba(60,50,95,.10),inset 0 1px 0 rgba(255,255,255,.7);color:var(--glass-text);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .2s;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg></button>
            </div>
          </div>
        </div>
        </sc-if>

        <!-- FLOW BUILDER -->
        <sc-if value="{{ rBuilder }}" hint-placeholder-val="{{ false }}">
        <div style="flex:1;display:flex;flex-direction:column;min-height:0;">
          <div style="display:flex;align-items:center;gap:10px;padding:10px 18px;border-bottom:1px solid var(--border);">
            <div style="flex:1;display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--text-subtle);"><div style="width:6px;height:6px;border-radius:50%;background:{{ builder.runDot }};"></div>{{ builder.runs }}</div>
            <button onClick="{{ builder.test }}" style="height:32px;padding:0 13px;border-radius:9px;border:1px solid var(--border);background:var(--bg-elev);color:var(--text);font-family:inherit;font-size:12.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:5px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M7 5v14l11-7z"/></svg>Test</button>
            <button onClick="{{ builder.toggleActive }}" style="width:48px;height:29px;border-radius:999px;border:none;cursor:pointer;background:{{ builder.trackbg }};position:relative;flex-shrink:0;transition:background .25s;padding:0;"><div style="position:absolute;top:3px;left:3px;width:23px;height:23px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ builder.knob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div></button>
          </div>
          <div class="scroll" style="flex:1;overflow-y:auto;padding:16px 18px 40px;">
            <div style="font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);margin-bottom:6px;">Flow name</div>
            <input value="{{ builder.name }}" onInput="{{ builder.rename }}" placeholder="Untitled flow" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:12px;padding:11px 13px;font-family:inherit;font-size:16px;font-weight:500;color:var(--text);outline:none;margin-bottom:20px;" />

            <div style="font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:none;color:var(--st-warm);margin-bottom:9px;display:flex;align-items:center;gap:6px;"><div style="width:7px;height:7px;border-radius:2px;background:var(--st-warm);"></div>When this happens</div>
            <sc-if value="{{ builder.hasTrigger }}" hint-placeholder-val="{{ true }}">
            <div onClick="{{ builder.trigger.open }}" style="border:none;background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:18px;padding:15px;display:flex;gap:12px;align-items:center;cursor:pointer;transition:transform .12s;" style-active="transform:scale(.99)">
              <div style="width:40px;height:40px;border-radius:11px;background:color-mix(in srgb,var(--st-warm) 15%,transparent);color:var(--st-warm);display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ builder.trigger.icon }}</div>
              <div style="flex:1;min-width:0;">
                <div style="font-size:14.5px;font-weight:500;">{{ builder.trigger.label }}</div>
                <div style="font-size:11.5px;color:var(--text-muted);margin-top:2px;line-height:1.35;">{{ builder.trigger.summary }}</div>
                <div style="font-size:9.5px;font-weight:500;letter-spacing:.03em;color:var(--text-subtle);margin-top:5px;font-family:ui-monospace,monospace;">{{ builder.trigger.sub }}</div>
              </div>
              <button onClick="{{ builder.swapTrigger }}" style="width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text-subtle);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 4l3 3-3 3M20 7H9a4 4 0 0 0-4 4M7 20l-3-3 3-3M4 17h11a4 4 0 0 0 4-4"/></svg></button>
            </div>
            </sc-if>
            <sc-if value="{{ builder.noTrigger }}" hint-placeholder-val="{{ false }}">
            <button onClick="{{ builder.addTrigger }}" style="width:100%;border:1.5px dashed color-mix(in srgb,var(--st-warm) 50%,var(--border-strong));background:color-mix(in srgb,var(--st-warm) 6%,transparent);border-radius:16px;padding:18px;color:var(--st-warm);font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>Choose a trigger</button>
            </sc-if>

            <sc-if value="{{ builder.hasTrigger }}" hint-placeholder-val="{{ true }}">
            <div style="display:flex;flex-direction:column;align-items:center;margin:2px 0;">
              <div style="width:2px;height:14px;background:var(--border-strong);"></div>
            </div>
            <div style="font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:none;color:var(--accent-deep);margin-bottom:9px;display:flex;align-items:center;gap:6px;"><div style="width:7px;height:7px;border-radius:2px;background:var(--accent);"></div>Then do this</div>

            <sc-for list="{{ builder.steps }}" as="st" hint-placeholder-count="2">
              <div style="display:flex;justify-content:center;margin:2px 0;opacity:{{ st.connOp }};transition:opacity .15s ease;"><button onClick="{{ st.insertBefore }}" style="width:24px;height:24px;border-radius:50%;border:1px dashed var(--border-strong);background:var(--bg);color:var(--text-subtle);cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button></div>
              <div data-step style="position:relative;border:none;background:linear-gradient(180deg,#fff,color-mix(in srgb,var(--bg-inset) 30%,#fff));border-radius:18px;padding:15px;box-shadow:{{ st.shadow }};transform:{{ st.tf }};z-index:{{ st.z }};transition:{{ st.trans }};">
                <div style="display:flex;gap:12px;align-items:center;">
                  <div onClick="{{ st.open }}" style="display:flex;gap:12px;align-items:center;cursor:pointer;flex:1;min-width:0;">
                    <div style="width:38px;height:38px;border-radius:11px;background:{{ st.iconbg }};color:{{ st.iconfg }};display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ st.icon }}</div>
                    <div style="flex:1;min-width:0;">
                      <div style="font-size:14.5px;font-weight:500;">{{ st.label }}</div>
                      <div style="font-size:12px;color:var(--text-subtle);margin-top:2px;line-height:1.35;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ st.summary }}</div>
                    </div>
                  </div>
                  <button onClick="{{ st.del }}" style="width:32px;height:32px;border:none;background:none;border-radius:8px;color:var(--text-subtle);cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;flex-shrink:0;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16M9 7V5h6v2M6 7l1 13h10l1-13"/></svg></button>
                  <div onPointerDown="{{ st.dragStart }}" onPointerMove="{{ st.dragMove }}" onPointerUp="{{ st.dragEnd }}" style="width:30px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--border-strong);cursor:{{ st.grab }};touch-action:none;flex-shrink:0;"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><circle cx="6" cy="4" r="1.4"/><circle cx="12" cy="4" r="1.4"/><circle cx="6" cy="9" r="1.4"/><circle cx="12" cy="9" r="1.4"/><circle cx="6" cy="14" r="1.4"/><circle cx="12" cy="14" r="1.4"/></svg></div>
                </div>
              </div>
            </sc-for>

            <div style="display:flex;justify-content:center;margin:2px 0;"><div style="width:2px;height:12px;background:var(--border-strong);"></div></div>
            <button onClick="{{ builder.addStep }}" style="width:100%;border:1.5px dashed var(--border-strong);background:transparent;border-radius:14px;padding:15px;color:var(--accent);font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>Add step</button>
            <div style="text-align:center;font-size:11px;color:var(--text-subtle);margin-top:14px;display:flex;align-items:center;justify-content:center;gap:6px;"><div style="width:7px;height:7px;border-radius:50%;border:2px solid var(--border-strong);"></div>End of flow</div>
            </sc-if>
          </div>
        </div>
        </sc-if>
      </div>
      </sc-if>

      <!-- ===== SETTINGS SHEET ===== -->
      <sc-if value="{{ sheetMounted }}" hint-placeholder-val="{{ false }}">
      <div onClick="{{ closeSettings }}" style="position:absolute;inset:0;z-index:55;background:rgba(0,0,0,.4);animation:{{ sheetScrimAnim }};"></div>
      <div style="position:absolute;left:0;right:0;bottom:0;z-index:56;background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border-radius:26px 26px 0 0;animation:{{ sheetAnim }};max-height:88%;display:flex;flex-direction:column;box-shadow:0 -10px 40px -10px rgba(0,0,0,.4);">
        <div style="padding:10px 0 4px;display:flex;justify-content:center;"><div style="width:38px;height:5px;border-radius:3px;background:var(--border-strong);"></div></div>
        <div class="scroll" style="overflow-y:auto;padding:8px 20px 40px;">
          <div style="display:flex;align-items:center;gap:12px;padding:8px 0 18px;">
            <div style="width:50px;height:50px;border-radius:50%;background:linear-gradient(150deg,var(--accent),var(--accent-deep));color:#fff;font-weight:500;font-size:17px;display:flex;align-items:center;justify-content:center;">DS</div>
            <div style="flex:1;"><div style="font-size:17px;font-weight:500;letter-spacing:-.02em;">The DS Labs</div><div style="font-size:12.5px;color:var(--text-muted);display:flex;align-items:center;gap:5px;"><div style="width:6px;height:6px;border-radius:50%;background:var(--st-done);"></div>@thedslabs · connected</div></div>
          </div>
          
          <div style="font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:none;color:var(--text-subtle);margin:8px 0 9px;">Preferences</div>
          <div style="border:1px solid var(--border);border-radius:15px;background:var(--bg-elev);overflow:hidden;">
            <sc-for list="{{ settingsRows }}" as="r" hint-placeholder-count="3">
              <div style="display:flex;align-items:center;gap:12px;padding:13px 14px;border-bottom:1px solid var(--border);">
                <div style="width:30px;height:30px;border-radius:8px;background:var(--accent-soft);color:var(--accent-deep);display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ r.icon }}</div>
                <div style="flex:1;"><div style="font-size:13.5px;font-weight:500;">{{ r.label }}</div><div style="font-size:11.5px;color:var(--text-subtle);">{{ r.sub }}</div></div>
                <button onClick="{{ r.toggle }}" style="width:48px;height:29px;border-radius:999px;border:none;cursor:pointer;background:{{ r.trackbg }};position:relative;flex-shrink:0;transition:background .25s;padding:0;"><div style="position:absolute;top:3px;left:3px;width:23px;height:23px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ r.knob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div></button>
              </div>
            </sc-for>
          </div>
          <button onClick="{{ signOut }}" style="width:100%;margin-top:18px;height:48px;border-radius:14px;border:1px solid var(--border);background:var(--bg-elev);color:var(--st-blocked);font-family:inherit;font-size:14.5px;font-weight:500;cursor:pointer;">Disconnect Instagram</button>
        </div>
      </div>
      </sc-if>

      <!-- ===== BUILDER SHEET (picker / config / test) ===== -->
      <sc-if value="{{ bsheetMounted }}" hint-placeholder-val="{{ false }}">
      <div onClick="{{ closeBsheet }}" style="position:absolute;inset:0;z-index:65;background:rgba(0,0,0,.4);animation:{{ bScrimAnim }};"></div>
      <div style="position:absolute;left:0;right:0;bottom:0;z-index:66;background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border-radius:26px 26px 0 0;animation:{{ bsheetAnim }};max-height:84%;display:flex;flex-direction:column;box-shadow:0 -10px 40px -10px rgba(0,0,0,.4);">
        <div style="padding:10px 0 4px;display:flex;justify-content:center;flex-shrink:0;"><div style="width:38px;height:5px;border-radius:3px;background:var(--border-strong);"></div></div>

        <!-- PICKER -->
        <sc-if value="{{ bsPicker }}" hint-placeholder-val="{{ false }}">
        <div style="padding:6px 20px 10px;flex-shrink:0;">
          <div style="font-size:19px;font-weight:500;letter-spacing:-.03em;">{{ picker.title }}</div>
        </div>
        <div class="scroll" style="overflow-y:auto;padding:4px 16px 36px;">
          <sc-for list="{{ picker.groups }}" as="g" hint-placeholder-count="2">
            <sc-if value="{{ g.hasTitle }}" hint-placeholder-val="{{ true }}">
            <div style="font-size:11px;font-weight:500;letter-spacing:.04em;color:var(--text-subtle);margin:14px 6px 8px;">{{ g.title }}</div>
            </sc-if>
            <sc-for list="{{ g.nodes }}" as="n" hint-placeholder-count="5">
              <button onClick="{{ n.pick }}" style="width:100%;display:flex;align-items:center;gap:12px;padding:12px;border:1px solid var(--border-subtle);background:var(--bg-elev);box-shadow:var(--shadow-card);border-radius:14px;margin-bottom:8px;cursor:pointer;font-family:inherit;text-align:left;">
                <div style="width:38px;height:38px;border-radius:10px;background:{{ n.bg }};color:{{ n.col }};display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ n.icon }}</div>
                <div style="flex:1;min-width:0;">
                  <div style="font-size:14px;font-weight:500;color:var(--text);">{{ n.label }}</div>
                  <div style="font-size:11.5px;color:var(--text-subtle);margin-top:1px;line-height:1.3;">{{ n.desc }}</div>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-subtle)" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </button>
            </sc-for>
          </sc-for>
        </div>
        </sc-if>

        <!-- CONFIG -->
        <sc-if value="{{ bsConfig }}" hint-placeholder-val="{{ false }}">
        <div style="padding:6px 20px 8px;flex-shrink:0;display:flex;align-items:center;gap:11px;">
          <div style="width:38px;height:38px;border-radius:10px;background:{{ config.bg }};color:{{ config.col }};display:flex;align-items:center;justify-content:center;flex-shrink:0;">{{ config.icon }}</div>
          <div><div style="font-size:18px;font-weight:500;letter-spacing:-.03em;">{{ config.title }}</div><div style="font-size:10.5px;color:var(--text-subtle);font-family:ui-monospace,monospace;">{{ config.sub }}</div></div>
        </div>
        <div class="scroll" style="overflow-y:auto;padding:8px 20px 20px;">
          <sc-if value="{{ config.empty }}" hint-placeholder-val="{{ false }}"><div style="font-size:13px;color:var(--text-muted);padding:8px 0 4px;line-height:1.5;">{{ config.emptyText }}</div></sc-if>
          <sc-for list="{{ config.fields }}" as="f" hint-placeholder-count="2">
            <div style="margin-bottom:16px;">
              <div style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin-bottom:7px;">{{ f.label }}</div>
              <sc-if value="{{ f.isText }}" hint-placeholder-val="{{ false }}">
                <input value="{{ f.value }}" onInput="{{ f.set }}" placeholder="{{ f.ph }}" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:11px;padding:11px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;" />
              </sc-if>
              <sc-if value="{{ f.isArea }}" hint-placeholder-val="{{ false }}">
                <textarea value="{{ f.value }}" onInput="{{ f.set }}" placeholder="{{ f.ph }}" rows="3" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:11px;padding:11px 13px;font-family:inherit;font-size:14px;line-height:1.4;color:var(--text);outline:none;resize:none;"></textarea>
              </sc-if>
              <sc-if value="{{ f.isNumber }}" hint-placeholder-val="{{ false }}">
                <div style="display:flex;align-items:center;gap:8px;"><input value="{{ f.value }}" onInput="{{ f.set }}" type="number" style="width:100px;border:1px solid var(--border);background:var(--bg-elev);border-radius:11px;padding:11px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;" /><span style="font-size:13px;color:var(--text-muted);">{{ f.unit }}</span></div>
              </sc-if>
              <sc-if value="{{ f.isSelect }}" hint-placeholder-val="{{ false }}">
                <div style="display:flex;flex-wrap:wrap;gap:7px;">
                  <sc-for list="{{ f.opts }}" as="o" hint-placeholder-count="3">
                    <button onClick="{{ o.set }}" style="height:34px;padding:0 14px;border-radius:10px;border:1px solid {{ o.bd }};background:{{ o.bg }};color:{{ o.fg }};font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;">{{ o.label }}</button>
                  </sc-for>
                </div>
              </sc-if>
              <sc-if value="{{ f.isChips }}" hint-placeholder-val="{{ false }}">
                <div style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:9px;">
                  <sc-for list="{{ f.chips }}" as="cp" hint-placeholder-count="2">
                    <div style="display:flex;align-items:center;gap:6px;height:32px;padding:0 6px 0 12px;border-radius:9px;background:var(--accent-soft);color:var(--accent-deep);font-size:13px;font-weight:500;">{{ cp.label }}<button onClick="{{ cp.remove }}" style="width:18px;height:18px;border-radius:50%;border:none;background:color-mix(in srgb,var(--accent) 22%,transparent);color:var(--accent-deep);cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg></button></div>
                  </sc-for>
                </div>
                <div style="display:flex;gap:8px;"><input value="{{ chipDraft }}" onInput="{{ setChipDraft }}" onKeyDown="{{ f.addChipKey }}" placeholder="Add a word + Enter" style="flex:1;border:1px solid var(--border);background:var(--bg-elev);border-radius:11px;padding:10px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;" /><button onClick="{{ f.addChip }}" style="width:44px;border-radius:11px;border:1px solid var(--border);background:var(--bg-inset);color:var(--accent);cursor:pointer;display:flex;align-items:center;justify-content:center;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></button></div>
              </sc-if>
            </div>
          </sc-for>
          <button onClick="{{ closeBsheet }}" style="width:100%;height:50px;border-radius:14px;border:none;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:15px;font-weight:500;cursor:pointer;margin-top:4px;">Done</button>
        </div>
        </sc-if>

        <!-- TEST -->
        <sc-if value="{{ bsTest }}" hint-placeholder-val="{{ false }}">
        <div style="padding:6px 20px 10px;flex-shrink:0;">
          <div style="font-size:19px;font-weight:500;letter-spacing:-.03em;">Test run</div>
          <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">How a contact would experience <b style="color:var(--text);">{{ test.title }}</b></div>
        </div>
        <div class="scroll" style="overflow-y:auto;padding:8px 16px 36px;display:flex;flex-direction:column;gap:6px;">
          <sc-for list="{{ test.msgs }}" as="m" hint-placeholder-count="3">
            <sc-if value="{{ m.isNote }}" hint-placeholder-val="{{ false }}">
              <div style="align-self:center;font-size:10.5px;font-weight:500;color:var(--text-subtle);background:var(--bg-inset);padding:5px 11px;border-radius:8px;margin:2px 0;">⚙ {{ m.text }}</div>
            </sc-if>
            <sc-if value="{{ m.isBubble }}" hint-placeholder-val="{{ true }}">
              <div style="display:flex;justify-content:{{ m.justify }};">
                <div style="max-width:78%;display:flex;flex-direction:column;align-items:{{ m.align }};gap:5px;">
                  <sc-if value="{{ m.tag }}" hint-placeholder-val="{{ false }}"><div style="font-size:9px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);">{{ m.tagText }}</div></sc-if>
                  <sc-if value="{{ m.hasText }}" hint-placeholder-val="{{ true }}"><div style="padding:9px 13px;border-radius:18px;font-size:13.5px;line-height:1.35;background:{{ m.bg }};color:{{ m.fg }};{{ m.corner }}">{{ m.text }}</div></sc-if>
                  <sc-if value="{{ m.hasBtns }}" hint-placeholder-val="{{ false }}">
                    <div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:flex-end;">
                      <sc-for list="{{ m.btns }}" as="b" hint-placeholder-count="2"><div style="font-size:12.5px;font-weight:500;color:var(--accent);border:1px solid color-mix(in srgb,var(--accent) 40%,transparent);border-radius:16px;padding:7px 13px;">{{ b }}</div></sc-for>
                    </div>
                  </sc-if>
                  <sc-if value="{{ m.hasCarousel }}" hint-placeholder-val="{{ false }}">
                    <div class="scroll" style="display:flex;gap:8px;overflow-x:auto;max-width:260px;">
                      <sc-for list="{{ m.cards }}" as="cd" hint-placeholder-count="2"><div style="flex:0 0 auto;width:110px;border:1px solid var(--border);border-radius:12px;overflow:hidden;background:var(--bg-elev);"><div style="height:80px;background:repeating-linear-gradient(135deg,var(--bg-inset),var(--bg-inset) 8px,var(--bg-sidebar) 8px,var(--bg-sidebar) 16px);display:flex;align-items:center;justify-content:center;font-weight:500;color:var(--text-subtle);opacity:.6;">{{ cd.mono }}</div><div style="padding:8px;"><div style="font-size:11px;font-weight:500;">{{ cd.title }}</div><div style="font-size:12px;font-weight:500;color:var(--accent);margin-top:3px;">{{ cd.price }}</div></div></div></sc-for>
                    </div>
                  </sc-if>
                </div>
              </div>
            </sc-if>
          </sc-for>
        </div>
        </sc-if>
      </div>
      </sc-if>

      <!-- ===== CUSTOMIZE SHEET ===== -->
      <sc-if value="{{ csheetMounted }}" hint-placeholder-val="{{ false }}">
      <div onClick="{{ closeCustomize }}" style="position:absolute;inset:0;z-index:65;background:rgba(0,0,0,.4);animation:{{ cScrimAnim }};"></div>
      <div style="position:absolute;left:0;right:0;bottom:0;z-index:66;background:var(--glass-smoke-bg);backdrop-filter:blur(var(--glass-blur)) saturate(140%);-webkit-backdrop-filter:blur(var(--glass-blur)) saturate(140%);border-radius:26px 26px 0 0;animation:{{ csheetAnim }};max-height:88%;display:flex;flex-direction:column;box-shadow:0 -10px 40px -10px rgba(0,0,0,.4);">
        <div style="padding:10px 0 4px;display:flex;justify-content:center;flex-shrink:0;"><div style="width:38px;height:5px;border-radius:3px;background:var(--border-strong);"></div></div>
        <div style="padding:6px 20px 10px;display:flex;align-items:center;flex-shrink:0;">
          <div style="font-size:19px;font-weight:500;letter-spacing:-.03em;flex:1;">Customise shop</div>
          <button onClick="{{ closeCustomize }}" style="height:32px;padding:0 15px;border-radius:9px;border:none;background:var(--text);color:var(--bg-elev);font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;">Done</button>
        </div>
        <div class="scroll" style="overflow-y:auto;padding:6px 20px 36px;">
          <div style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin-bottom:7px;">Store name</div>
          <input value="{{ customize.title }}" onInput="{{ customize.setTitle }}" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:11px;padding:11px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;margin-bottom:18px;" />
          <div style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin-bottom:9px;">Accent</div>
          <div style="display:flex;gap:13px;margin-bottom:20px;padding-left:2px;">
            <sc-for list="{{ customize.accents }}" as="a" hint-placeholder-count="6">
              <button onClick="{{ a.set }}" style="width:32px;height:32px;border-radius:50%;border:none;cursor:pointer;background:{{ a.color }};box-shadow:{{ a.ring }};padding:0;"></button>
            </sc-for>
          </div>
          <div style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin-bottom:7px;">Hero layout</div>
          <div style="display:flex;gap:4px;background:var(--bg-inset);border-radius:11px;padding:3px;margin-bottom:18px;">
            <sc-for list="{{ customize.heroLayoutOpts }}" as="o" hint-placeholder-count="2"><button onClick="{{ o.set }}" style="flex:1;height:34px;border:none;border-radius:8px;font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;background:{{ o.bg }};color:{{ o.fg }};box-shadow:{{ o.sh }};">{{ o.label }}</button></sc-for>
          </div>
          <div style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin-bottom:7px;">Headline</div>
          <input value="{{ customize.headline }}" onInput="{{ customize.setHeadline }}" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:11px;padding:11px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;margin-bottom:14px;" />
          <div style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin-bottom:7px;">Tagline</div>
          <input value="{{ customize.tagline }}" onInput="{{ customize.setTagline }}" style="width:100%;border:1px solid var(--border);background:var(--bg-elev);border-radius:11px;padding:11px 13px;font-family:inherit;font-size:14px;color:var(--text);outline:none;margin-bottom:18px;" />
          <div style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:none;color:var(--text-subtle);margin-bottom:7px;">Buy button label</div>
          <div style="display:flex;gap:4px;background:var(--bg-inset);border-radius:11px;padding:3px;margin-bottom:18px;">
            <sc-for list="{{ customize.buyLabelOpts }}" as="o" hint-placeholder-count="3"><button onClick="{{ o.set }}" style="flex:1;height:34px;border:none;border-radius:8px;font-family:inherit;font-size:13.5px;font-weight:500;cursor:pointer;background:{{ o.bg }};color:{{ o.fg }};box-shadow:{{ o.sh }};">{{ o.label }}</button></sc-for>
          </div>
          <div style="background:var(--bg-elev);border-radius:13px;overflow:hidden;border:.5px solid var(--border);">
            <div style="display:flex;align-items:center;padding:13px 14px;"><span style="flex:1;font-size:15px;">Show featured rail</span><button onClick="{{ customize.toggleFeatured }}" style="width:48px;height:29px;border-radius:999px;border:none;cursor:pointer;background:{{ customize.ftTrack }};position:relative;flex-shrink:0;transition:background .25s;padding:0;"><div style="position:absolute;top:3px;left:3px;width:23px;height:23px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ customize.ftKnob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div></button></div>
            <div style="height:.5px;background:var(--border);margin-left:14px;"></div>
            <div style="display:flex;align-items:center;padding:13px 14px;"><span style="flex:1;font-size:15px;">Show about section</span><button onClick="{{ customize.toggleAbout }}" style="width:48px;height:29px;border-radius:999px;border:none;cursor:pointer;background:{{ customize.abTrack }};position:relative;flex-shrink:0;transition:background .25s;padding:0;"><div style="position:absolute;top:3px;left:3px;width:23px;height:23px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.3);transform:{{ customize.abKnob }};transition:transform .26s cubic-bezier(.3,1.4,.5,1);"></div></button></div>
          </div>
        </div>
      </div>
      </sc-if>

      <!-- toast -->
      <sc-if value="{{ toast }}" hint-placeholder-val="{{ false }}">
        <div style="position:absolute;left:50%;bottom:118px;transform:translateX(-50%);z-index:68;background:var(--text);color:var(--bg);font-size:13px;font-weight:500;padding:11px 18px;border-radius:13px;box-shadow:var(--shadow-pop);animation:slideup .3s ease;white-space:nowrap;">{{ toast }}</div>
      </sc-if>

      <div style="position:absolute;bottom:8px;left:50%;transform:translateX(-50%);width:134px;height:5px;border-radius:3px;background:var(--text);opacity:.32;z-index:70;"></div>
    </div>
  </div>
</div>
</x-dc>
