      setLight:this.setTheme('light'), setDark:this.setTheme('dark'),
      lightBg:!isDark?'var(--bg-elev)':'transparent', lightFg:!isDark?A:'var(--text-muted)', lightSh:!isDark?'var(--shadow-card)':'none',
      darkBg:isDark?'var(--bg-elev)':'transparent', darkFg:isDark?A:'var(--text-muted)', darkSh:isDark?'var(--shadow-card)':'none',
      settingsRows, signOut:this.signOut,
      bsheetMounted:s.bsheetMounted, bsheetAnim: s.bsheetClosing?'shout .26s ease forwards':'shin .34s cubic-bezier(.16,.84,.44,1) forwards', bScrimAnim: s.bsheetClosing?'fout .24s forwards':'fin .3s forwards', closeBsheet:this.closeBsheet,
      bsPicker:!!(bs&&bs.kind==='picker'), bsConfig:!!(bs&&bs.kind==='config'), bsTest:!!(bs&&bs.kind==='test'),
      picker, config, test, chipDraft:s.chipDraft, setChipDraft:this.setChipDraft,
      pullH:(s.pullDist||0)+'px', pullTrans:s.pulling?'none':'height .3s cubic-bezier(.32,.72,0,1)', pullLabel:s.refreshing?'Refreshing…':s.pullDist>52?'Release to refresh':'Pull to refresh', pullSpin:s.refreshing?'animation:spin .7s linear infinite;':'', pullDown:this.pullDown, pullMove:this.pullMove, pullUp:this.pullUp,
      toast:s.toast,
    };
  }
}
</script>
</body>
</html>
