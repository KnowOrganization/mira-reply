# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real secrets; only the example template
.env
.env.*
!.env.example
!.env.local.example

# local account/token store (Instagram access token lives here)
.mira/

# runtime SQLite store (live IG user data — not source)
/data/

# nested unrelated Xcode/Swift project (has its own git repo)
/mira/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
