# ───────────────────────────────────────────────────────────────
# Mira — environment template
# Copy to .env.local and fill values. .env.local is gitignored.
# NEVER commit real secrets or the Instagram access token.
# ───────────────────────────────────────────────────────────────

# ── Instagram / Meta ───────────────────────────────────────────
# Create app at https://developers.facebook.com/apps → Add product "Instagram"
# Use "Instagram API with Instagram Login" (no FB Page needed for Creator)
META_APP_ID=
META_APP_SECRET=

# OAuth redirect — must match exactly what's whitelisted in Meta dashboard
# Local:  http://localhost:3000/api/ig/callback   (dev server runs on 3000)
# Tunnel: https://YOUR-TUNNEL.ngrok-free.dev/api/ig/callback
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Webhook verify token — invent a random string, set same value in Meta dashboard
META_WEBHOOK_VERIFY_TOKEN=mira_dev_verify_change_me

# ── Reply behavior ─────────────────────────────────────────────
# "shadow" (drafts only) | "assisted" (approve before send) | "auto" (send immediately)
MIRA_REPLY_MODE=assisted

# ── Ollama (local LLM) ─────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── NOTE ───────────────────────────────────────────────────────
# Instagram account access token is stored at ~/.mira/ig.json (mode 0600)
# after OAuth. It is NOT an env var and must never be committed.

# Scaling infra (Phase 1+2)
DATABASE_URL=postgresql://localhost:5432/mira
REDIS_URL=redis://127.0.0.1:6379
