# ───────────────────────────────────────────────────────────────
# Mira — environment template
# Copy to .env.local and fill values. .env.local is gitignored.
# NEVER commit real secrets or the Instagram access token.
# ───────────────────────────────────────────────────────────────

# ── Instagram / Meta ───────────────────────────────────────────
# Create app at https://developers.facebook.com/apps → Add product "Instagram"
# Use "Instagram API with Instagram Login" (no FB Page needed for Creator)
META_APP_ID=
META_APP_SECRET=

# OAuth redirect — must match exactly what's whitelisted in Meta dashboard
# Local (no tunnel):     http://localhost:3000/api/ig/callback
# Dev tunnel (webhooks):  https://dev.yourdomain.com/api/ig/callback  (cloudflared named tunnel)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Webhook verify token — invent a random string, set same value in Meta dashboard
META_WEBHOOK_VERIFY_TOKEN=mira_dev_verify_change_me

# ── Reply behavior ─────────────────────────────────────────────
# Legacy single mode (seeds both channels on first run):
# "shadow" (drafts only) | "assisted" (approve before send) | "auto" (send immediately)
MIRA_REPLY_MODE=assisted
# Per-channel posture (shadow|assisted|auto). Comments are public + ban-sensitive
# (default assisted = you approve); DMs are 1:1 (default auto = Mira answers).
MIRA_COMMENT_MODE=assisted
MIRA_DM_MODE=auto
# Always reply ("Grok-style"): reply to almost everything; only rulebook skips
# (spam/troll/sexual/business/two-users-chatting) stay silent. Set 0 to disable.
MIRA_ALWAYS_REPLY=1

# ── Worker concurrency (separate comment + DM lanes) ───────────
WORKER_CONCURRENCY_COMMENTS=10
WORKER_CONCURRENCY_DM=10

# ── NVIDIA NIM (generation) ────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# Comma-separated priority list. First model tried; rotates on any failure.
# Leave unset to use the built-in 26-model list.
NIM_MODELS=
NIM_TIMEOUT_MS=30000

# ── Ollama (embeddings only — semantic KB recall) ──────────────
# Generation uses NIM. Ollama is kept only for local vector embeddings.
# If Ollama is down, semantic recall degrades gracefully to keyword matching.
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── NOTE ───────────────────────────────────────────────────────
# Instagram account access token is stored at ~/.mira/ig.json (mode 0600)
# after OAuth. It is NOT an env var and must never be committed.

# Scaling infra (Phase 1+2)
DATABASE_URL=postgresql://localhost:5432/mira
REDIS_URL=redis://127.0.0.1:6379
